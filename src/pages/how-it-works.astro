---
import BaseLayout from "../layouts/BaseLayout.astro";
import ZeroForcingHero from "../components/ZeroForcingHero.astro";
import HullPeelMotif from "../components/HullPeelMotif.astro";
import DelaunayMotif from "../components/DelaunayMotif.astro";
import { CONTENT_POINTS } from "../data/content-points";
import { peelLayers } from "../lib/geometry/hull";
import { relatedIndices, edgesFromNeighbors, MIN_POINTS_FOR_DELAUNAY } from "../lib/geometry/related";
import { buildAdjacency, findMinimumZeroForcingSet } from "../lib/zeroForcing";
import { copy, copyTemplate } from "../lib/copy";

const workLayers = peelLayers(CONTENT_POINTS, (p) => [p.recency, p.depth]);
const orderedWorkCount = workLayers.reduce((n, layer) => n + layer.length, 0);

const delaunayEdges = edgesFromNeighbors(relatedIndices(CONTENT_POINTS.map((p) => [p.topic, p.recency])));
const delaunayActive = CONTENT_POINTS.length >= MIN_POINTS_FOR_DELAUNAY;

const zfGraph = buildAdjacency(
  CONTENT_POINTS.map((p) => p.slug),
  delaunayEdges.map(([a, b]) => [CONTENT_POINTS[a].slug, CONTENT_POINTS[b].slug]),
);
const zfSeeds = findMinimumZeroForcingSet(zfGraph);

const zeroForcingStat = copyTemplate("howItWorks.zeroForcing.stat", {
  seedCount: zfSeeds.length,
  seedPlural: zfSeeds.length === 1 ? "" : "s",
  nodeCount: CONTENT_POINTS.length,
});
const zeroForcingBody = copyTemplate("howItWorks.zeroForcing.body", {
  nodeCount: CONTENT_POINTS.length,
  seedCount: zfSeeds.length,
});
const workOrderingStat = copyTemplate("howItWorks.workOrdering.stat", {
  layerCount: workLayers.length,
  layerPlural: workLayers.length === 1 ? "" : "s",
  itemCount: orderedWorkCount,
});
const delaunayStat = copyTemplate("howItWorks.delaunay.stat", {
  pointCount: CONTENT_POINTS.length,
  belowThreshold: delaunayActive ? "" : " (below threshold)",
});
const delaunayBody = copyTemplate("howItWorks.delaunay.body", {
  minPoints: MIN_POINTS_FOR_DELAUNAY,
});
---

<BaseLayout
  title={copy("howItWorks.meta.title")}
  description={copy("howItWorks.meta.description")}
  railSections={[
    { label: copy("howItWorks.railLabel.zeroForcing"), href: "#zero-forcing" },
    { label: copy("howItWorks.railLabel.workOrdering"), href: "#work-ordering" },
    { label: copy("howItWorks.railLabel.delaunay"), href: "#delaunay" },
  ]}
>
  <section class="py-10 scroll-mt-16">
    <h2 class="font-display text-h3 border-l-2 border-moss pl-4 mb-6">{copy("howItWorks.heading")}</h2>
    <p class="font-mono text-xs text-stone mb-6">
      {copy("howItWorks.intro")}
    </p>
    <div class="flex flex-col gap-14 max-w-4xl">
      <div id="zero-forcing" class="reveal flex flex-col md:flex-row gap-6 md:gap-10 md:items-center scroll-mt-24">
        <div class="flex flex-col gap-3 md:flex-1">
          <h3 class="font-display text-2xl text-parchment">{copy("howItWorks.zeroForcing.title")}</h3>
          <p class="font-mono text-xs text-stone">{zeroForcingStat}</p>
          <p class="text-parchment/90" set:html={zeroForcingBody} />
        </div>
        <div class="max-w-sm mx-auto md:mx-0 md:flex-1">
          <ZeroForcingHero showCaption={false} />
        </div>
      </div>
      <div id="work-ordering" class="reveal flex flex-col md:flex-row-reverse gap-6 md:gap-10 md:items-center scroll-mt-24">
        <div class="flex flex-col gap-3 md:flex-1">
          <h3 class="font-display text-2xl text-parchment">{copy("howItWorks.workOrdering.title")}</h3>
          <p class="font-mono text-xs text-stone">{workOrderingStat}</p>
          <p class="text-parchment/90">{copy("howItWorks.workOrdering.body")}</p>
        </div>
        <div class="max-w-sm mx-auto md:mx-0 md:flex-1">
          <HullPeelMotif layers={workLayers} width={400} height={257} class="w-full h-auto" />
        </div>
      </div>
      <div id="delaunay" class="reveal flex flex-col md:flex-row gap-6 md:gap-10 md:items-center scroll-mt-24">
        <div class="flex flex-col gap-3 md:flex-1">
          <h3 class="font-display text-2xl text-parchment">{copy("howItWorks.delaunay.title")}</h3>
          <p class="font-mono text-xs text-stone">{delaunayStat}</p>
          <p class="text-parchment/90" set:html={delaunayBody} />
        </div>
        {
          delaunayActive && (
            <div class="max-w-sm mx-auto md:mx-0 md:flex-1">
              <DelaunayMotif points={CONTENT_POINTS} edges={delaunayEdges} width={400} height={257} class="w-full h-auto" />
            </div>
          )
        }
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const reveals = document.querySelectorAll<HTMLElement>(".reveal");
  const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  if (prefersReducedMotion) {
    reveals.forEach((el) => el.classList.add("in-view"));
  } else {
    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            entry.target.classList.add("in-view");
            observer.unobserve(entry.target);
          }
        }
      },
      { threshold: 0.1 },
    );
    reveals.forEach((el) => observer.observe(el));
  }
</script>

<style>
  .reveal {
    opacity: 0;
    transform: translateY(12px);
    transition:
      opacity var(--duration-base, 300ms) var(--ease-field),
      transform var(--duration-base, 300ms) var(--ease-field);
  }
  .reveal.in-view {
    opacity: 1;
    transform: translateY(0);
  }
</style>
