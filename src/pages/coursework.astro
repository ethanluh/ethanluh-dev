---
import BaseLayout from "../layouts/BaseLayout.astro";
import SpecimenCard from "../components/SpecimenCard.astro";
import { coursework } from "../content/coursework";
import { copy } from "../lib/copy";
---

<BaseLayout title={copy("coursework.meta.title")} description={copy("coursework.meta.description")}>
  <section class="max-w-3xl mx-auto px-6 py-10 scroll-mt-16">
    <h2 class="font-display text-h3 border-l-2 border-moss pl-4 mb-6">{copy("coursework.heading")}</h2>
    <div class="flex flex-col gap-4">
      {
        coursework.map((entry) => (
          <SpecimenCard number={entry.number} title={entry.title} tag={entry.tag} description={entry.description} />
        ))
      }
    </div>
  </section>
</BaseLayout>
