---
import BaseLayout from "../layouts/BaseLayout.astro";
import SpecimenCard from "../components/SpecimenCard.astro";
import { coursework } from "../content/coursework";
---

<BaseLayout title="Coursework — Ethan Luh" description="Coursework for Ethan Luh, CS/Math/Stats student at Penn State Behrend.">
  <section class="max-w-3xl mx-auto px-6 py-10 scroll-mt-16">
    <h2 class="font-display text-h3 border-l-2 border-moss pl-4 mb-6">Coursework</h2>
    <div class="flex flex-col gap-4">
      {
        coursework.map((entry) => (
          <SpecimenCard number={entry.number} title={entry.title} tag={entry.tag} description={entry.description} />
        ))
      }
    </div>
  </section>
</BaseLayout>
