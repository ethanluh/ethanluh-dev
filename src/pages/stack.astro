---
import BaseLayout from "../layouts/BaseLayout.astro";
import { copy } from "../lib/copy";

const techCategories = [
  { label: copy("stack.tech.languages.label"), items: copy("stack.tech.languages.items").split(" · ") },
  { label: copy("stack.tech.mlVision.label"), items: copy("stack.tech.mlVision.items").split(" · ") },
  { label: copy("stack.tech.site.label"), items: copy("stack.tech.site.items").split(" · ") },
];

const mathCategories = [
  { label: copy("stack.math.graphTheory.label"), items: copy("stack.math.graphTheory.items").split(" · ") },
  { label: copy("stack.math.geometry.label"), items: copy("stack.math.geometry.items").split(" · ") },
  { label: copy("stack.math.statistics.label"), items: copy("stack.math.statistics.items").split(" · ") },
];
---

<BaseLayout
  title={copy("stack.meta.title")}
  description={copy("stack.meta.description")}
  railSections={[
    { label: copy("stack.railLabel.tech"), href: "#tech-stack" },
    { label: copy("stack.railLabel.math"), href: "#math-stack" },
  ]}
>
  <section class="section-block scroll-mt-16">
    <h2 class="font-display text-h3 rule-draw mb-6">{copy("stack.heading")}</h2>
    <p class="font-mono text-xs text-stone mb-10 max-w-2xl">
      {copy("stack.intro")}
    </p>

    <div class="flex flex-col gap-14 max-w-3xl">
      <div id="tech-stack" class="reveal scroll-mt-24">
        <h3 class="font-display text-2xl text-parchment mb-6">{copy("stack.techHeading")}</h3>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {
            techCategories.map((cat) => (
              <div class="stack-category bg-bark rounded-r-sm border-l-[3px] border-moss p-5">
                <p class="font-mono text-[0.65rem] uppercase tracking-widest text-moss mb-3">{cat.label}</p>
                <div class="flex flex-wrap gap-2">
                  {cat.items.map((item) => (
                    <span class="chip font-mono text-xs text-stone">{item}</span>
                  ))}
                </div>
              </div>
            ))
          }
        </div>
      </div>

      <div id="math-stack" class="reveal scroll-mt-24">
        <h3 class="font-display text-2xl text-parchment mb-6">{copy("stack.mathHeading")}</h3>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {
            mathCategories.map((cat) => (
              <div class="stack-category bg-bark rounded-r-sm border-l-[3px] border-moss p-5">
                <p class="font-mono text-[0.65rem] uppercase tracking-widest text-moss mb-3">{cat.label}</p>
                <div class="flex flex-wrap gap-2">
                  {cat.items.map((item) => (
                    <span class="chip font-mono text-xs text-stone">{item}</span>
                  ))}
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const reveals = document.querySelectorAll<HTMLElement>(".reveal");
  const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  if (prefersReducedMotion) {
    reveals.forEach((el) => el.classList.add("in-view"));
  } else {
    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            entry.target.classList.add("in-view");
            observer.unobserve(entry.target);
          }
        }
      },
      { threshold: 0.1, rootMargin: "0px 0px -8% 0px" },
    );
    reveals.forEach((el) => observer.observe(el));
  }
</script>
