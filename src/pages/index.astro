---
import BaseLayout from "../layouts/BaseLayout.astro";
import SpecimenCard from "../components/SpecimenCard.astro";
import FeaturedProjectCard from "../components/FeaturedProjectCard.astro";
import ZeroForcingHero from "../components/ZeroForcingHero.astro";
import Cta from "../components/Cta.astro";
import { research } from "../content/research";
import { projects } from "../content/projects";
import { experience } from "../content/experience";
import { CONTENT_POINTS } from "../data/content-points";
import { CONTACT_EMAIL, SOCIAL_LINKS, PERSONAL_SITE } from "../content/site";
import { peelLayers } from "../lib/geometry/hull";
import { relatedIndices, edgesFromNeighbors, MIN_POINTS_FOR_DELAUNAY } from "../lib/geometry/related";
import { copy } from "../lib/copy";

// --- Unified Work stream: Research + Projects + Experience, one adapter shape ---
type WorkEntry = {
  slug: string;
  kind: "research" | "project" | "experience";
  number: string;
  title: string;
  tag: string;
  description: string;
  impact?: string;
  href?: string;
  image?: string;
  imageAlt?: string;
  links?: { label: string; href: string }[];
  techStack?: string[];
  mathStack?: string[];
};

const workEntries: WorkEntry[] = [
  ...research.map(
    (r): WorkEntry => ({
      slug: r.slug,
      kind: "research",
      number: r.number,
      title: r.title,
      tag: `${r.status} · updated ${r.updated}`,
      description: r.abstract,
      impact: r.impact,
      links: r.links,
    }),
  ),
  ...projects.map(
    (p): WorkEntry => ({
      slug: p.slug,
      kind: "project",
      number: p.number,
      title: p.title,
      tag: p.tag,
      description: p.description,
      impact: p.impact,
      href: p.href,
      links: p.links,
      image: p.image,
      imageAlt: p.imageAlt,
      techStack: p.techStack,
      mathStack: p.mathStack,
    }),
  ),
  ...experience.map(
    (e): WorkEntry => ({
      slug: e.slug,
      kind: "experience",
      number: e.number,
      title: e.role,
      tag: `${e.org} · ${e.dates}`,
      description: e.description,
      impact: e.impact,
    }),
  ),
];
const workBySlug = new Map(workEntries.map((w) => [w.slug, w]));

// --- Ordering: convex-hull peeling over (recency, depth), across all kinds ---
// layers[0] is the Pareto-extreme set (not dominated on both axes by any
// other single item) — this replaces both the hand-set `featured` flag and
// the research/projects/experience grouping. Order is layer, not type.
// Shipped work gets a depth bonus, unshipped a smaller penalty, before
// peeling — enough that shallow shipped side projects don't out-rank deep
// unshipped research for the featured slot (see /how-it-works).
const effectiveDepth = (p: (typeof CONTENT_POINTS)[number]) =>
  p.depth * (p.shipped === true ? 1.3 : p.shipped === false ? 0.85 : 1);
const workLayers = peelLayers(CONTENT_POINTS, (p) => [p.recency, effectiveDepth(p)]);
const byWeight = (p: (typeof CONTENT_POINTS)[number]) => p.recency + effectiveDepth(p);
const orderedWorkSlugs = workLayers.flatMap((layer) => [...layer].sort((a, b) => byWeight(b) - byWeight(a))).map((p) => p.slug);
const orderedWork = orderedWorkSlugs.map((slug) => workBySlug.get(slug)).filter((w): w is WorkEntry => Boolean(w));

const [featuredWork, ...restWork] = orderedWork;

// --- Status + rank-reason microcopy, derived from the same hull-peel data ---
const contentPointBySlug = new Map(CONTENT_POINTS.map((p) => [p.slug, p]));
const layer0Slugs = new Set((workLayers[0] ?? []).map((p) => p.slug));

function statusFor(slug: string): "live" | "shipped" | "inProgress" {
  if (slug === "quire") return "live";
  const point = contentPointBySlug.get(slug);
  if (point?.shipped === false) return "inProgress";
  return "shipped";
}

function rankReasonFor(slug: string): "featured" | "frontier" | "shippedRecent" | "earlier" {
  if (slug === orderedWorkSlugs[0]) return "featured";
  if (layer0Slugs.has(slug)) return "frontier";
  const point = contentPointBySlug.get(slug);
  if (point?.shipped === true && point.recency >= 0.5) return "shippedRecent";
  return "earlier";
}

// --- Related-content: Delaunay triangulation over (topic, recency) ---
// Gated on MIN_POINTS_FOR_DELAUNAY — below that, neighbors are near-arbitrary.
const contentIndexBySlug = new Map(CONTENT_POINTS.map((p, i) => [p.slug, i]));
const neighborIndices = relatedIndices(CONTENT_POINTS.map((p) => [p.topic, p.recency]));
const delaunayEdges = edgesFromNeighbors(neighborIndices);
const delaunayActive = CONTENT_POINTS.length >= MIN_POINTS_FOR_DELAUNAY;

function relatedFor(slug: string) {
  if (!delaunayActive) return [];
  const i = contentIndexBySlug.get(slug);
  if (i === undefined) return [];
  return neighborIndices[i].map((j) => {
    const p = CONTENT_POINTS[j];
    return { title: p.title, href: p.href };
  });
}

function delaunayFor(slug: string) {
  return { points: CONTENT_POINTS, edges: delaunayEdges, activeSlug: slug };
}
---

<BaseLayout
  title={copy("home.meta.title")}
  description={copy("home.meta.description")}
  railSections={[
    { label: copy("home.work.heading"), href: "#work" },
    { label: copy("home.about.heading"), href: "#about" },
    { label: copy("home.contact.heading"), href: "#contact" },
  ]}
>
  <section class="section-block-hero flex flex-col lg:flex-row lg:items-center lg:justify-between gap-10 lg:min-h-[calc(88svh-var(--header-height))]">
    <div class="max-w-2xl flex flex-col gap-3 lg:gap-4">
      <h1 class="hero-enter font-display text-h1" style="--enter-order: 0">
        {copy("home.hero.headline")}
      </h1>
      <p class="hero-enter text-parchment/90 max-w-xl leading-snug sm:leading-relaxed" style="--enter-order: 1">
        {copy("home.hero.subhead")}
      </p>
      <div class="hero-enter" style="--enter-order: 2">
        <p class="font-mono text-xs uppercase tracking-widest text-stone leading-snug">
          {copy("home.hero.chipProgram")}
          <br />
          {copy("home.hero.chipGradDate")}
        </p>
        <div class="flex flex-wrap gap-1.5 mt-2">
          <span class="border border-bark rounded-sm px-2 py-0.5 text-[0.8125rem] text-stone font-mono">
            <span class="text-moss" aria-hidden="true">&#9679;</span> {copy("home.hero.chipShipped")}
          </span>
          <span class="border border-bark rounded-sm px-2 py-0.5 text-[0.8125rem] text-stone font-mono">
            {copy("home.hero.chipTeam")}
          </span>
          <span class="border border-bark rounded-sm px-2 py-0.5 text-[0.8125rem] text-stone font-mono">
            {copy("home.hero.chipResearch")}
          </span>
        </div>
      </div>
      <div class="hero-enter flex flex-wrap items-center gap-3" style="--enter-order: 3">
        <Cta variant="primary" href={`mailto:${CONTACT_EMAIL}`} arrow>{copy("home.hero.ctaEmail")}</Cta>
        <Cta variant="secondary" resumeTrigger>{copy("home.hero.ctaResume")}</Cta>
      </div>
      <p class="font-mono text-xs text-stone">
        <a href="#content-zero-forcing-polytopes-research" class="tap-target hover:text-moss transition-colors duration-150">
          {copy("home.hero.ctaMath")}
        </a>
      </p>
    </div>
    <div class="hero-enter w-full max-w-[22rem] mx-auto lg:max-w-none lg:mx-0 lg:w-[26rem] lg:shrink-0" style="--enter-order: 5">
      <ZeroForcingHero />
    </div>
  </section>

  <section id="work" class="section-block scroll-mt-16">
    <h2 class="reveal rule-draw font-display text-h3 mb-6">{copy("home.work.heading")}</h2>
    <div class="mb-12">
      <p class="font-mono text-xs text-stone mb-2">
        {copy("home.work.introPrefix")} <a href="/how-it-works" class="text-moss hover:text-parchment transition-colors duration-150">{copy("home.work.introLinkLabel")}</a>.
      </p>
      <p class="font-mono text-xs text-stone">
        {copy("home.work.stackLine")} <a href="/stack" class="text-moss hover:text-parchment transition-colors duration-150">{copy("home.work.stackLinkLabel")}</a>
      </p>
    </div>

    {featuredWork && (
      <div class="reveal mb-16">
        <FeaturedProjectCard
          id={`content-${featuredWork.slug}`}
          number={featuredWork.number}
          title={featuredWork.title}
          tag={featuredWork.tag}
          description={featuredWork.description}
          impact={featuredWork.impact}
          href={featuredWork.href}
          links={featuredWork.links}
          image={featuredWork.image}
          imageAlt={featuredWork.imageAlt}
          kindLabel={featuredWork.kind}
          eyebrow={copy("home.work.featuredEyebrow")}
          statusKind={statusFor(featuredWork.slug)}
          statusLabel={copy(`home.work.status.${statusFor(featuredWork.slug)}`)}
          rankReason={copy(`home.work.rankReason.${rankReasonFor(featuredWork.slug)}`)}
          related={relatedFor(featuredWork.slug)}
          delaunay={delaunayFor(featuredWork.slug)}
          techStack={featuredWork.techStack}
          mathStack={featuredWork.mathStack}
        />
      </div>
    )}

    <div class="flex flex-col gap-14">
      {
        (["project", "experience", "research"] as const).map((kind) => {
          const entries = restWork.filter((entry) => entry.kind === kind);
          if (entries.length === 0) return null;
          return (
            <div>
              <p class="font-mono text-[0.65rem] uppercase tracking-widest text-stone mb-3 flex items-center gap-3 track-label">
                {copy(`home.work.trackLabel.${kind}`)}
              </p>
              <div class="flex flex-col gap-4">
                {entries.map((entry, i) => (
                  <div class="reveal" style={`--reveal-delay: ${Math.min(i * 90, 270)}ms`}>
                    <SpecimenCard
                      id={`content-${entry.slug}`}
                      number={entry.number}
                      title={entry.title}
                      tag={entry.tag}
                      description={entry.description}
                      impact={entry.impact}
                      links={entry.links ?? (entry.href ? [{ label: "view", href: entry.href }] : [])}
                      image={entry.image}
                      imageAlt={entry.imageAlt}
                      variant={entry.kind}
                      kindLabel={entry.kind}
                      statusKind={statusFor(entry.slug)}
                      statusLabel={copy(`home.work.status.${statusFor(entry.slug)}`)}
                      rankReason={copy(`home.work.rankReason.${rankReasonFor(entry.slug)}`)}
                      related={relatedFor(entry.slug)}
                      delaunay={delaunayFor(entry.slug)}
                      techStack={entry.techStack}
                      mathStack={entry.mathStack}
                    />
                  </div>
                ))}
              </div>
            </div>
          );
        })
      }
    </div>

    <p class="font-mono text-xs text-stone mt-12">
      {copy("home.work.outro")}{" "}
      <button type="button" data-resume-trigger class="tap-target text-moss hover:text-parchment transition-colors duration-150 cursor-pointer">
        {copy("home.work.outroResumeLabel")}
      </button>{" "}
      {copy("home.work.outroContactSuffix")}{" "}
      <a href="#contact" class="tap-target text-moss hover:text-parchment transition-colors duration-150">
        {copy("home.work.outroContactLabel")}
      </a>.
    </p>
  </section>

  <section id="about" class="section-block scroll-mt-16">
    <h2 class="reveal rule-draw font-display text-h3 mb-6">{copy("home.about.heading")}</h2>
    <div class="reveal grid grid-cols-1 sm:grid-cols-[3fr_2fr] gap-10 items-start">
      <div class="max-w-xl text-parchment/90 flex flex-col gap-4">
        <p>{copy("home.about.paragraph1")}</p>
        <p>{copy("home.about.paragraph2")}</p>
      </div>
      <div class="about-photo-frame relative max-w-[220px]">
        <div class="about-photo-border absolute inset-0 border-2 border-moss rounded-sm" aria-hidden="true"></div>
        <img
          src="/placeholder-headshot.svg"
          alt=""
          class="about-photo relative rounded-sm w-full h-auto block"
          loading="lazy"
        />
      </div>
    </div>
  </section>

  <section id="contact" class="section-block pb-24 border-t border-bark scroll-mt-16">
    <div class="max-w-2xl">
      <h2 class="reveal rule-draw font-display text-h3 mb-6">{copy("home.contact.heading")}</h2>
      <p class="reveal text-parchment/90 mb-8" style="--reveal-delay: 90ms">
        {copy("home.contact.body")}
      </p>
      <div class="reveal flex flex-wrap items-center gap-3 mb-8" style="--reveal-delay: 180ms">
        <Cta variant="primary" href={`mailto:${CONTACT_EMAIL}`} arrow>{copy("home.contact.ctaEmail")}</Cta>
        <Cta variant="secondary" resumeTrigger>{copy("home.contact.ctaResume")}</Cta>
      </div>
      <p class="reveal font-mono text-xs text-stone" style="--reveal-delay: 270ms">
        {copy("home.contact.elsewhere")}{" "}
        {SOCIAL_LINKS.map((link, i) => (
          <>
            {i > 0 && <span aria-hidden="true"> &middot; </span>}
            <a href={link.href} target="_blank" rel="noopener noreferrer" class="tap-target hover:text-moss transition-colors duration-150">
              {link.label}
            </a>
          </>
        ))}
        <span aria-hidden="true"> &middot; </span>
        <a href={PERSONAL_SITE.href} class="tap-target hover:text-moss transition-colors duration-150">
          {PERSONAL_SITE.label}
        </a>
      </p>
    </div>
  </section>
</BaseLayout>

<script>
  const reveals = document.querySelectorAll<HTMLElement>(".reveal");
  const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  if (prefersReducedMotion) {
    reveals.forEach((el) => el.classList.add("in-view"));
  } else {
    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            entry.target.classList.add("in-view");
            observer.unobserve(entry.target);
          }
        }
      },
      { threshold: 0.1, rootMargin: "0px 0px -8% 0px" },
    );
    reveals.forEach((el) => observer.observe(el));
  }
</script>

<style>
  .track-label::after {
    content: "";
    flex: 1;
    height: 1px;
    background: var(--color-bark);
  }

  .about-photo {
    filter: grayscale(100%) contrast(1) brightness(90%);
    transition:
      transform var(--duration-base) var(--ease-field),
      filter var(--duration-base) var(--ease-field);
  }
  .about-photo-border {
    transform: translate(10px, 10px);
    transition: transform var(--duration-base) var(--ease-field);
  }
  @media (prefers-reduced-motion: no-preference) {
    .about-photo-frame:hover .about-photo,
    .about-photo-frame:focus-within .about-photo {
      transform: translate(-4px, -4px);
      filter: none;
    }
    .about-photo-frame:hover .about-photo-border,
    .about-photo-frame:focus-within .about-photo-border {
      transform: translate(14px, 14px);
    }
  }
</style>
