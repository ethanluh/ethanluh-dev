---
import BaseLayout from "../layouts/BaseLayout.astro";
import SpecimenCard from "../components/SpecimenCard.astro";
import FeaturedProjectCard from "../components/FeaturedProjectCard.astro";
import ZeroForcingHero from "../components/ZeroForcingHero.astro";
import HStarMotif from "../components/HStarMotif.astro";
import { research } from "../content/research";
import { projects } from "../content/projects";
import { experience } from "../content/experience";
import { coursework } from "../content/coursework";
import { CONTENT_POINTS } from "../data/content-points";
import { peelLayers } from "../lib/geometry/hull";
import { relatedIndices, edgesFromNeighbors, MIN_POINTS_FOR_DELAUNAY } from "../lib/geometry/related";
import { buildAdjacency, findMinimumZeroForcingSet } from "../lib/zeroForcing";

// --- Unified Work stream: Research + Projects + Experience, one adapter shape ---
type WorkEntry = {
  slug: string;
  kind: "research" | "project" | "experience";
  number: string;
  title: string;
  tag: string;
  description: string;
  href?: string;
  image?: string;
  links?: { label: string; href: string }[];
};

const workEntries: WorkEntry[] = [
  ...research.map(
    (r): WorkEntry => ({
      slug: r.slug,
      kind: "research",
      number: r.number,
      title: r.title,
      tag: `${r.status} · updated ${r.updated}`,
      description: r.abstract,
      links: r.links,
    }),
  ),
  ...projects.map(
    (p): WorkEntry => ({
      slug: p.slug,
      kind: "project",
      number: p.number,
      title: p.title,
      tag: p.tag,
      description: p.description,
      href: p.href,
      image: p.image,
    }),
  ),
  ...experience.map(
    (e): WorkEntry => ({
      slug: e.slug,
      kind: "experience",
      number: e.number,
      title: e.role,
      tag: `${e.org} · ${e.dates}`,
      description: e.description,
    }),
  ),
];
const workBySlug = new Map(workEntries.map((w) => [w.slug, w]));

// --- Ordering: convex-hull peeling over (recency, depth), across all kinds ---
// layers[0] is the Pareto-extreme set (not dominated on both axes by any
// other single item) — this replaces both the hand-set `featured` flag and
// the research/projects/experience grouping. Order is layer, not type.
const workLayers = peelLayers(CONTENT_POINTS, (p) => [p.recency, p.depth]);
const byWeight = (p: (typeof CONTENT_POINTS)[number]) => p.recency + p.depth;
const orderedWorkSlugs = workLayers.flatMap((layer) => [...layer].sort((a, b) => byWeight(b) - byWeight(a))).map((p) => p.slug);
const orderedWork = orderedWorkSlugs.map((slug) => workBySlug.get(slug)).filter((w): w is WorkEntry => Boolean(w));

const [featuredWork, ...restWork] = orderedWork;
const layerIndexBySlug = new Map(workLayers.flatMap((layer, i) => layer.map((p) => [p.slug, i] as const)));

// --- Related-content: Delaunay triangulation over (topic, recency) ---
// Gated on MIN_POINTS_FOR_DELAUNAY — below that, neighbors are near-arbitrary.
const contentIndexBySlug = new Map(CONTENT_POINTS.map((p, i) => [p.slug, i]));
const neighborIndices = relatedIndices(CONTENT_POINTS.map((p) => [p.topic, p.recency]));
const delaunayEdges = edgesFromNeighbors(neighborIndices);
const delaunayActive = CONTENT_POINTS.length >= MIN_POINTS_FOR_DELAUNAY;

function relatedFor(slug: string) {
  if (!delaunayActive) return [];
  const i = contentIndexBySlug.get(slug);
  if (i === undefined) return [];
  return neighborIndices[i].map((j) => {
    const p = CONTENT_POINTS[j];
    return { title: p.title, href: p.href };
  });
}

function delaunayFor(slug: string) {
  return { points: CONTENT_POINTS, edges: delaunayEdges, activeSlug: slug };
}

// --- Zero forcing hero stats, for the colophon note (same graph the hero renders) ---
const zfGraph = buildAdjacency(
  CONTENT_POINTS.map((p) => p.slug),
  delaunayEdges.map(([a, b]) => [CONTENT_POINTS[a].slug, CONTENT_POINTS[b].slug]),
);
const zfSeeds = findMinimumZeroForcingSet(zfGraph);
---

<BaseLayout
  title="Ethan Luh"
  description="CS/Math/Stats student at Penn State Behrend — research and projects."
>
  <section class="max-w-[90rem] mx-auto px-6 sm:px-10 lg:px-16 pt-12 pb-2 flex flex-col lg:flex-row lg:items-center lg:justify-between gap-10">
    <div class="max-w-2xl">
      <h1 class="font-display text-h1 leading-tight mb-4">
        Building at the edge of graph theory and code.
      </h1>
      <p class="max-w-xl text-parchment/90">
        CS/Math/Stats student at Penn State Behrend, researching zero forcing
        polytopes.
      </p>
    </div>
    <div class="w-full lg:w-[30vw] lg:shrink-0">
      <ZeroForcingHero />
    </div>
  </section>

  <section id="work" class="max-w-3xl mx-auto px-6 pt-2 pb-10 scroll-mt-16">
    <h2 class="font-display text-h3 border-l-2 border-moss pl-4 mb-6">Work</h2>
    <p class="font-mono text-xs text-stone mb-6">
      Research, projects, and experience — ordered by convex-hull peel layer over
      (recency, depth), not by type. See colophon.
    </p>
    <div class="flex flex-col gap-4">
      {featuredWork && (
        <div class="reveal">
          <FeaturedProjectCard
            id={`content-${featuredWork.slug}`}
            number={featuredWork.number}
            title={featuredWork.title}
            tag={featuredWork.tag}
            description={featuredWork.description}
            href={featuredWork.href}
            image={featuredWork.image}
            kindLabel={featuredWork.kind}
            related={relatedFor(featuredWork.slug)}
            delaunay={delaunayFor(featuredWork.slug)}
          />
        </div>
      )}
      {
        restWork.map((entry) => (
          <div class="reveal">
            <SpecimenCard
              id={`content-${entry.slug}`}
              number={entry.number}
              title={entry.title}
              tag={entry.tag}
              description={entry.description}
              links={entry.href ? [{ label: "view", href: entry.href }] : (entry.links ?? [])}
              kindLabel={`${entry.kind} · layer ${layerIndexBySlug.get(entry.slug) ?? 0}`}
              related={relatedFor(entry.slug)}
              delaunay={delaunayFor(entry.slug)}
            />
          </div>
        ))
      }
    </div>
  </section>

  <section id="coursework" class="max-w-3xl mx-auto px-6 py-10 scroll-mt-16">
    <h2 class="font-display text-h3 border-l-2 border-moss pl-4 mb-6">Coursework</h2>
    <div class="flex flex-col gap-4">
      {
        coursework.map((entry) => (
          <div class="reveal">
            <SpecimenCard
              number={entry.number}
              title={entry.title}
              tag={entry.tag}
              description={entry.description}
            />
          </div>
        ))
      }
    </div>
  </section>

  <section id="about" class="max-w-3xl mx-auto px-6 py-10 scroll-mt-16">
    <h2 class="font-display text-h3 border-l-2 border-moss pl-4 mb-6">About</h2>
    <div class="reveal grid grid-cols-1 sm:grid-cols-[3fr_2fr] gap-10 items-start">
      <div class="max-w-xl text-parchment/90">
        <!-- placeholder copy — swap in real bio detail before launch -->
        <p>
          Still writing this section. For now: CS/Math/Stats at Penn State
          Behrend, spending most of my time between graph theory proofs and the
          code that tests them.
        </p>
      </div>
      <div class="about-photo-frame relative max-w-[220px]">
        <div class="about-photo-border absolute inset-0 border-2 border-moss rounded-sm" aria-hidden="true"></div>
        <img
          src="/placeholder-headshot.svg"
          alt=""
          class="about-photo relative rounded-sm w-full h-auto block"
          loading="lazy"
        />
      </div>
    </div>
  </section>

  <section id="colophon" class="max-w-3xl mx-auto px-6 py-10 scroll-mt-16">
    <h2 class="font-display text-h3 border-l-2 border-moss pl-4 mb-6">Colophon</h2>
    <div class="flex flex-col gap-8">
      <div id="colophon-zero-forcing" class="reveal flex flex-col sm:flex-row gap-6 items-start sm:items-center scroll-mt-24">
        <p class="font-mono text-xs text-stone shrink-0 sm:w-40">
          {zfSeeds.length} seed{zfSeeds.length === 1 ? "" : "s"} · {CONTENT_POINTS.length} nodes
        </p>
        <p class="text-parchment/90 max-w-md">
          The hero graph at the top of the page is this site's actual content
          — the same {CONTENT_POINTS.length} items listed below, connected by
          the same Delaunay edges used for "related" — animated by{" "}
          <strong>zero forcing</strong>, the color-change rule from the
          research area above: a colored vertex with exactly one uncolored
          neighbor forces it to color. The {zfSeeds.length} moss-colored
          seeds on load are a real computed minimum zero forcing set, not a
          hand-picked example; everything else propagates in the order the
          rule actually forces it. It's a live instance of the math, not an
          illustration of it — hover a node for its title, click to visit.
        </p>
      </div>
      <div class="reveal flex flex-col sm:flex-row gap-6 items-start sm:items-center">
        <HStarMotif vectorId="cube4" mode="bar" width={160} height={40} class="shrink-0" />
        <p class="text-parchment/90 max-w-md">
          The bars above are the h*-vector of the 4-cube, <span class="font-mono text-xs text-stone">(1, 11, 11, 1)</span> —
          a classical Ehrhart theory example (an Eulerian number sequence),
          kept here purely as a textbook illustration, distinct from the zero
          forcing hero above, which renders real content data. Once the zero
          forcing polytope result with Hanely is finalized, this slot gets
          reassigned to that h*-vector specifically.
        </p>
      </div>
      <div class="reveal flex flex-col sm:flex-row gap-6 items-start sm:items-center">
        <p class="font-mono text-xs text-stone shrink-0 sm:w-40">
          {workLayers.length} layer{workLayers.length === 1 ? "" : "s"} · {orderedWork.length} items
        </p>
        <p class="text-parchment/90 max-w-md">
          Work isn't grouped by type (research/project/experience) anymore —
          it's ordered by convex-hull peel layer over (recency, depth). The
          Featured card is the top of layer 0, the Pareto-extreme set not
          dominated on both axes by any other single item; everything else
          follows in layer order, labeled with its kind and layer number. The
          nav bar up top is peeled the same way, over (depth, recency) per
          section, using the same <code class="text-xs">convexHull</code>
          function — sections in an inner layer render slightly dimmer.
        </p>
      </div>
      <div class="reveal flex flex-col sm:flex-row gap-6 items-start sm:items-center">
        <p class="font-mono text-xs text-stone shrink-0 sm:w-40">
          {CONTENT_POINTS.length} points{delaunayActive ? "" : " (below threshold)"}
        </p>
        <p class="text-parchment/90 max-w-md">
          The small node-and-edge diagram next to each "related" list is the
          actual Delaunay triangulation over hand-placed (topic, recency)
          coordinates — every point and edge in the full graph, with the
          current card's node and its neighbors highlighted. Below{" "}
          {MIN_POINTS_FOR_DELAUNAY} points the triangulation gets arbitrary,
          so the feature stays off until there's enough content to make it
          mean something.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const reveals = document.querySelectorAll<HTMLElement>(".reveal");
  const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  if (prefersReducedMotion) {
    reveals.forEach((el) => el.classList.add("in-view"));
  } else {
    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            entry.target.classList.add("in-view");
            observer.unobserve(entry.target);
          }
        }
      },
      { threshold: 0.1 },
    );
    reveals.forEach((el) => observer.observe(el));
  }
</script>

<style>
  .reveal {
    opacity: 0;
    transform: translateY(12px);
    transition:
      opacity var(--duration-base, 300ms) var(--ease-field),
      transform var(--duration-base, 300ms) var(--ease-field);
  }
  .reveal.in-view {
    opacity: 1;
    transform: translateY(0);
  }
  .reveal.in-view :global(.hstar-draw .hstar-stroke) {
    stroke-dashoffset: 0;
  }
  .reveal.in-view :global(.hstar-draw .hstar-dot) {
    opacity: 1;
    transform: scale(1);
  }
  .reveal.in-view :global(.hstar-draw .hstar-fill) {
    opacity: 1;
  }

  .about-photo {
    filter: grayscale(100%) contrast(1) brightness(90%);
    transition:
      transform var(--duration-base) var(--ease-field),
      filter var(--duration-base) var(--ease-field);
  }
  .about-photo-border {
    transform: translate(10px, 10px);
    transition: transform var(--duration-base) var(--ease-field);
  }
  @media (prefers-reduced-motion: no-preference) {
    .about-photo-frame:hover .about-photo,
    .about-photo-frame:focus-within .about-photo {
      transform: translate(-4px, -4px);
      filter: none;
    }
    .about-photo-frame:hover .about-photo-border,
    .about-photo-frame:focus-within .about-photo-border {
      transform: translate(14px, 14px);
    }
  }
</style>
