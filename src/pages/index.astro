---
import BaseLayout from "../layouts/BaseLayout.astro";
import SpecimenCard from "../components/SpecimenCard.astro";
import FeaturedProjectCard from "../components/FeaturedProjectCard.astro";
import ZeroForcingHero from "../components/ZeroForcingHero.astro";
import GraphDivider from "../components/GraphDivider.astro";
import { research } from "../content/research";
import { projects } from "../content/projects";

const featuredProject = projects.find((p) => p.featured) ?? projects[0];
const restProjects = projects.filter((p) => p !== featuredProject);
---

<BaseLayout
  title="Ethan Luh"
  description="CS/Math/Stats student at Penn State Behrend — research and projects."
>
  <section class="max-w-3xl mx-auto px-6 pt-12 pb-10 grid grid-cols-1 lg:grid-cols-[3fr_2fr] gap-10 items-center">
    <div>
      <h1 class="font-display text-h1 leading-tight mb-4">
        Building at the edge of graph theory and code.
      </h1>
      <p class="max-w-xl text-parchment/90">
        CS/Math/Stats student at Penn State Behrend, researching zero forcing
        polytopes.
      </p>
    </div>
    <ZeroForcingHero />
  </section>

  <section id="research" class="max-w-3xl mx-auto px-6 py-10 scroll-mt-16">
    <h2 class="font-display text-h3 border-l-2 border-moss pl-4 mb-6">Research</h2>
    <div class="flex flex-col gap-4">
      {
        research.map((entry) => (
          <div class="reveal">
            <SpecimenCard
              number={entry.number}
              title={entry.title}
              tag={`${entry.status} · updated ${entry.updated}`}
              description={entry.abstract}
              links={entry.links}
            />
          </div>
        ))
      }
    </div>
  </section>

  <GraphDivider />

  <section id="projects" class="max-w-3xl mx-auto px-6 py-10 scroll-mt-16">
    <h2 class="font-display text-h3 border-l-2 border-moss pl-4 mb-6">Projects</h2>
    <div class="flex flex-col gap-4">
      <div class="reveal">
        <FeaturedProjectCard
          number={featuredProject.number}
          title={featuredProject.title}
          tag={featuredProject.tag}
          description={featuredProject.description}
          href={featuredProject.href}
          image={featuredProject.image}
        />
      </div>
      {
        restProjects.map((entry) => (
          <div class="reveal">
            <SpecimenCard
              number={entry.number}
              title={entry.title}
              tag={entry.tag}
              description={entry.description}
              links={entry.href ? [{ label: "view", href: entry.href }] : []}
              pills
            />
          </div>
        ))
      }
    </div>
  </section>

  <GraphDivider flip />

  <section id="about" class="max-w-3xl mx-auto px-6 py-10 scroll-mt-16">
    <h2 class="font-display text-h3 border-l-2 border-moss pl-4 mb-6">About</h2>
    <div class="reveal grid grid-cols-1 sm:grid-cols-[3fr_2fr] gap-10 items-start">
      <div class="max-w-xl text-parchment/90">
        <!-- placeholder copy — swap in real bio detail before launch -->
        <p>
          Still writing this section. For now: CS/Math/Stats at Penn State
          Behrend, spending most of my time between graph theory proofs and the
          code that tests them.
        </p>
      </div>
      <div class="about-photo-frame relative max-w-[220px]">
        <div class="about-photo-border absolute inset-0 border-2 border-moss rounded-sm" aria-hidden="true"></div>
        <img
          src="/placeholder-headshot.svg"
          alt=""
          class="about-photo relative rounded-sm w-full h-auto block"
          loading="lazy"
        />
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const reveals = document.querySelectorAll<HTMLElement>(".reveal");
  const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  if (prefersReducedMotion) {
    reveals.forEach((el) => el.classList.add("in-view"));
  } else {
    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            entry.target.classList.add("in-view");
            observer.unobserve(entry.target);
          }
        }
      },
      { threshold: 0.1 },
    );
    reveals.forEach((el) => observer.observe(el));
  }
</script>

<style>
  .reveal {
    opacity: 0;
    transform: translateY(12px);
    transition:
      opacity var(--duration-base, 300ms) var(--ease-field),
      transform var(--duration-base, 300ms) var(--ease-field);
  }
  .reveal.in-view {
    opacity: 1;
    transform: translateY(0);
  }

  .about-photo {
    filter: grayscale(100%) contrast(1) brightness(90%);
    transition:
      transform var(--duration-base) var(--ease-field),
      filter var(--duration-base) var(--ease-field);
  }
  .about-photo-border {
    transform: translate(10px, 10px);
    transition: transform var(--duration-base) var(--ease-field);
  }
  @media (prefers-reduced-motion: no-preference) {
    .about-photo-frame:hover .about-photo,
    .about-photo-frame:focus-within .about-photo {
      transform: translate(-4px, -4px);
      filter: none;
    }
    .about-photo-frame:hover .about-photo-border,
    .about-photo-frame:focus-within .about-photo-border {
      transform: translate(14px, 14px);
    }
  }
</style>
