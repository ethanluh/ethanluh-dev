---
interface DelaunayPoint {
  slug: string;
  title: string;
  topic: number;
  recency: number;
}

interface Props {
  points: DelaunayPoint[];
  edges: [number, number][];
  // Omit to render an "overview" of the full graph with no single node
  // singled out, instead of the per-card focus-on-one-node treatment.
  activeSlug?: string;
  width?: number;
  height?: number;
  class?: string;
}

const { points, edges, activeSlug, width = 140, height = 90, class: className = "" } = Astro.props;

const padding = 10;
const scaleX = width - padding * 2;
const scaleY = height - padding * 2;
const pos = (p: DelaunayPoint): [number, number] => [
  padding + p.topic * scaleX,
  padding + (1 - p.recency) * scaleY,
];

const overview = activeSlug === undefined;
const activeIndex = overview ? -1 : points.findIndex((p) => p.slug === activeSlug);
const neighborSet = new Set(
  edges.flatMap(([a, b]) => {
    if (a === activeIndex) return [b];
    if (b === activeIndex) return [a];
    return [];
  }),
);
---

<svg
  class:list={["delaunay-motif", className]}
  width={width}
  height={height}
  viewBox={`0 0 ${width} ${height}`}
  aria-hidden="true"
  focusable="false"
>
  {
    edges.map(([a, b]) => {
      const [x1, y1] = pos(points[a]);
      const [x2, y2] = pos(points[b]);
      const active = overview || a === activeIndex || b === activeIndex;
      return <line x1={x1} y1={y1} x2={x2} y2={y2} class={active ? "edge-active" : "edge-dim"} />;
    })
  }
  {
    points.map((p, i) => {
      const [cx, cy] = pos(p);
      const cls = overview ? "node-neighbor" : i === activeIndex ? "node-active" : neighborSet.has(i) ? "node-neighbor" : "node-dim";
      const r = overview ? 3 : i === activeIndex ? 4 : neighborSet.has(i) ? 3 : 2;
      const above = cy > height / 2;
      const tooltipWidth = 200;
      const tooltipHeight = 42;
      const tooltipX = Math.min(Math.max(cx - tooltipWidth / 2, 0), Math.max(width - tooltipWidth, 0));
      const tooltipY = above ? cy - tooltipHeight - 10 : cy + 10;
      return (
        <g class="node-group">
          <circle cx={cx} cy={cy} r={r + 4} class="node-hit" />
          <circle cx={cx} cy={cy} r={r} class={cls} />
          <foreignObject x={tooltipX} y={tooltipY} width={tooltipWidth} height={tooltipHeight} class="node-tooltip-anchor">
            <div class="node-tooltip-wrap">
              <div class="node-tooltip font-mono">{p.title}</div>
            </div>
          </foreignObject>
        </g>
      );
    })
  }
</svg>

<style>
  .edge-dim {
    stroke: var(--color-stone);
    stroke-width: 1;
    opacity: 0.2;
  }
  .edge-active {
    stroke: var(--color-moss);
    stroke-width: 1.5;
    opacity: 0.85;
  }
  .node-dim {
    fill: var(--color-stone);
    opacity: 0.4;
  }
  .node-neighbor {
    fill: var(--color-moss);
    opacity: 0.75;
  }
  .node-active {
    fill: var(--color-moss);
    opacity: 1;
  }
  .node-hit {
    fill: transparent;
  }
  .delaunay-motif {
    overflow: visible;
  }
  .node-tooltip-anchor {
    overflow: visible;
    pointer-events: none;
  }
  .node-tooltip-wrap {
    display: flex;
    justify-content: center;
    width: 100%;
    height: 100%;
  }
  .node-tooltip {
    width: fit-content;
    max-width: 100%;
    padding: 0.35rem 0.6rem;
    font-size: 0.7rem;
    line-height: 1.3;
    text-align: center;
    overflow-wrap: break-word;
    color: var(--color-parchment);
    background: var(--color-canopy);
    border: 1px solid color-mix(in srgb, var(--color-moss) 30%, transparent);
    border-radius: 0.25rem;
    box-shadow: 0 8px 16px -8px rgb(0 0 0 / 0.5);
    opacity: 0;
    transition: opacity 120ms var(--ease-field);
  }
  .node-group:hover .node-tooltip {
    opacity: 1;
  }
</style>
