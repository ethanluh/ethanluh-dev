---
// The hero is a live rendering of the site's actual content as a graph,
// animated by the zero forcing color-change rule from the zero forcing
// polytopes research area. Nodes are CONTENT_POINTS (the same data driving
// the Work section and hull-peeling order), edges are the Delaunay
// triangulation already computed for the related-content system — this view
// has no data model of its own. The minimum zero forcing set and forcing
// order are computed here at build time; no zero forcing logic ships to the
// client, it only plays back the precomputed sequence via CSS.
import { CONTENT_POINTS } from "../data/content-points";
import { relatedIndices, edgesFromNeighbors, MIN_POINTS_FOR_DELAUNAY } from "../lib/geometry/related";
import { buildAdjacency, findMinimumZeroForcingSet, simulateForcing } from "../lib/zeroForcing";

const delaunayActive = CONTENT_POINTS.length >= MIN_POINTS_FOR_DELAUNAY;
const neighborIndices = relatedIndices(CONTENT_POINTS.map((p) => [p.topic, p.recency]));
const indexEdges = delaunayActive ? edgesFromNeighbors(neighborIndices) : [];

const slugEdges: [string, string][] = indexEdges.map(([a, b]) => [
  CONTENT_POINTS[a].slug,
  CONTENT_POINTS[b].slug,
]);

// Raw recency/depth values cluster badly at pixel scale (same lesson noted
// in docs/hull-peeling-nav.md for the shelved hull concept) — rank each axis
// independently so the layout spreads without changing the underlying data
// or the peel-layer/Delaunay computations, which operate on raw values.
function ranks(values: number[]): number[] {
  const order = values.map((_, i) => i).sort((a, b) => values[a] - values[b] || a - b);
  const r = new Array<number>(values.length);
  order.forEach((originalIndex, rank) => {
    r[originalIndex] = rank;
  });
  return r;
}

const n = CONTENT_POINTS.length;
const xRanks = ranks(CONTENT_POINTS.map((p) => p.recency));
const yRanks = ranks(CONTENT_POINTS.map((p) => p.depth));

const width = 400;
const height = 320;
const pad = 44;
const spread = (rank: number) => (n > 1 ? rank / (n - 1) : 0.5);

const nodes = CONTENT_POINTS.map((p, i) => ({
  slug: p.slug,
  title: p.title,
  href: p.href,
  x: pad + spread(xRanks[i]) * (width - pad * 2),
  y: pad + (1 - spread(yRanks[i])) * (height - pad * 2),
}));
const nodeBySlug = new Map(nodes.map((n) => [n.slug, n]));

const graph = buildAdjacency(
  CONTENT_POINTS.map((p) => p.slug),
  slugEdges,
);
const seeds = findMinimumZeroForcingSet(graph);
const forcing = simulateForcing(graph, seeds);

const renderEdges = slugEdges.map(([a, b], index) => {
  const forceA = forcing.get(a);
  const forceB = forcing.get(b);
  const forcingRound = forceA?.via === b ? forceA.round : forceB?.via === a ? forceB.round : null;
  return { from: nodeBySlug.get(a)!, to: nodeBySlug.get(b)!, index, forcingRound };
});

const renderNodes = nodes.map((node) => ({
  node,
  round: forcing.get(node.slug)?.round ?? 0,
}));
---

<div class="zf-hero-wrap">
  <svg class="zf-hero w-full h-auto max-w-lg" viewBox={`0 0 ${width} ${height}`} fill="none" aria-hidden="true" focusable="false">
    {
      renderEdges.map(({ from, to, index, forcingRound }) => (
        <line
          class:list={["zf-edge", forcingRound !== null && "zf-forcing"]}
          style={{
            "--i": index,
            ...(forcingRound !== null ? { "--round": forcingRound } : {}),
          }}
          x1={from.x}
          y1={from.y}
          x2={to.x}
          y2={to.y}
        />
      ))
    }

    {
      renderNodes.map(({ node, round }) => (
        <a href={node.href} class="zf-node-link" tabindex="-1">
          <circle class:list={["zf-node", round === 0 ? "zf-seed" : "zf-forced"]} style={{ "--round": round }} cx={node.x} cy={node.y} r={9} />
          <title>{node.title}</title>
        </a>
      ))
    }
  </svg>

  <ul class="sr-only">
    {
      nodes.map((node) => (
        <li>
          <a href={node.href}>{node.title}</a>
        </li>
      ))
    }
  </ul>
</div>

<style>
  .zf-edge {
    stroke: var(--color-stone);
    stroke-width: 1.5;
    stroke-linecap: round;
    stroke-dasharray: 500;
    stroke-dashoffset: 500;
    animation: zf-draw var(--duration-base) var(--ease-field) forwards;
    animation-delay: calc(var(--i) * var(--duration-stagger) / 5);
  }

  .zf-edge.zf-forcing {
    animation:
      zf-draw var(--duration-base) var(--ease-field) forwards,
      zf-pulse var(--duration-base) var(--ease-field) forwards;
    animation-delay:
      calc(var(--i) * var(--duration-stagger) / 5),
      calc(var(--round) * var(--duration-stagger) - 60ms);
  }

  .zf-node-link {
    cursor: pointer;
  }

  .zf-node {
    stroke: var(--color-stone);
    stroke-width: 1.5;
    fill: var(--color-canopy);
  }

  .zf-seed {
    fill: var(--color-moss);
  }

  .zf-forced {
    animation: zf-force var(--duration-base) var(--ease-field) forwards;
    animation-delay: calc(var(--round) * var(--duration-stagger));
  }

  @keyframes zf-draw {
    to {
      stroke-dashoffset: 0;
    }
  }

  @keyframes zf-force {
    to {
      fill: var(--color-moss);
    }
  }

  @keyframes zf-pulse {
    0% {
      stroke: var(--color-stone);
    }
    50% {
      stroke: var(--color-moss);
      stroke-width: 2.5;
    }
    100% {
      stroke: var(--color-stone);
      stroke-width: 1.5;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .zf-edge,
    .zf-edge.zf-forcing,
    .zf-forced {
      animation-duration: 0s !important;
      animation-delay: 0s !important;
    }
  }
</style>
