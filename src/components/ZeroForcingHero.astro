---
// Semi-abstract zero forcing graph: two seed-colored vertices force their
// uncolored neighbors to color in turn, one edge at a time.
---

<svg
  class="zf-hero w-full h-auto max-w-md"
  viewBox="0 0 320 260"
  fill="none"
  aria-hidden="true"
  focusable="false"
>
  <line class="zf-edge" style="--d: 0" x1="60" y1="70" x2="150" y2="40" />
  <line class="zf-edge" style="--d: 1" x1="150" y1="40" x2="230" y2="80" />
  <line class="zf-edge" style="--d: 2" x1="60" y1="70" x2="80" y2="160" />
  <line class="zf-edge" style="--d: 3" x1="80" y1="160" x2="170" y2="190" />
  <line class="zf-edge" style="--d: 4" x1="170" y1="190" x2="260" y2="160" />
  <line class="zf-edge" style="--d: 5" x1="230" y1="80" x2="260" y2="160" />

  <circle class="zf-node zf-seed" style="--d: 0" cx="60" cy="70" r="9" />
  <circle class="zf-node zf-forced" style="--d: 1" cx="150" cy="40" r="9" />
  <circle class="zf-node zf-forced" style="--d: 2" cx="80" cy="160" r="9" />
  <circle class="zf-node zf-forced" style="--d: 3" cx="230" cy="80" r="9" />
  <circle class="zf-node zf-forced" style="--d: 4" cx="170" cy="190" r="9" />
  <circle class="zf-node zf-forced" style="--d: 5" cx="260" cy="160" r="9" />
</svg>

<style>
  .zf-edge {
    stroke: var(--color-stone);
    stroke-width: 1.5;
    stroke-linecap: round;
    stroke-dasharray: 220;
    stroke-dashoffset: 220;
    animation: zf-draw var(--duration-base) var(--ease-field) forwards;
    animation-delay: calc(var(--d) * var(--duration-stagger));
  }

  .zf-node {
    stroke: var(--color-stone);
    stroke-width: 1.5;
    fill: var(--color-canopy);
  }

  .zf-seed {
    fill: var(--color-moss);
  }

  .zf-forced {
    animation: zf-force var(--duration-base) var(--ease-field) forwards;
    animation-delay: calc(var(--d) * var(--duration-stagger));
  }

  @keyframes zf-draw {
    to {
      stroke-dashoffset: 0;
    }
  }

  @keyframes zf-force {
    to {
      fill: var(--color-moss);
    }
  }
</style>
