---
// The hero is a live rendering of the site's actual content as a graph,
// animated by the zero forcing color-change rule from the zero forcing
// polytopes research area. Nodes are CONTENT_POINTS (the same data driving
// the Work section and hull-peeling order), edges are the Delaunay
// triangulation already computed for the related-content system — this view
// has no data model of its own. The minimum zero forcing set and forcing
// order are computed here at build time; no zero forcing logic ships to the
// client, it only plays back the precomputed sequence via CSS.
import { CONTENT_POINTS } from "../data/content-points";
import { relatedIndices, edgesFromNeighbors, MIN_POINTS_FOR_DELAUNAY } from "../lib/geometry/related";
import { buildAdjacency, findMinimumZeroForcingSet, simulateForcing } from "../lib/zeroForcing";
import { copy } from "../lib/copy";

const delaunayActive = CONTENT_POINTS.length >= MIN_POINTS_FOR_DELAUNAY;
const neighborIndices = relatedIndices(CONTENT_POINTS.map((p) => [p.topic, p.recency]));
const indexEdges = delaunayActive ? edgesFromNeighbors(neighborIndices) : [];

const slugEdges: [string, string][] = indexEdges.map(([a, b]) => [
  CONTENT_POINTS[a].slug,
  CONTENT_POINTS[b].slug,
]);

// Card-scale canvas, sized for sitting next to the heading rather than
// spanning the page — everything below (padding, node radius, stroke
// widths, label offsets) is derived from this so resizing it again later
// stays proportional instead of needing a second round of magic numbers.
//
// A Delaunay triangulation is only planar (no crossing edges) when drawn on
// the same coordinates it was computed from (topic, recency) — same lesson
// as docs/hull-peeling-nav.md's hull/display-coordinate mismatch bug. To
// actually read as the same graph as DelaunayMotif.astro (not just use the
// same edge list), the canvas has to reproduce its aspect ratio and padding
// proportions too. Derive height and per-axis padding from DelaunayMotif's
// own 140×90 canvas / 10px padding instead of picking new numbers.
const width = 400;
const motifWidth = 140;
const motifHeight = 90;
const motifPadding = 10;
const height = Math.round((width / motifWidth) * motifHeight);
const padX = (motifPadding / motifWidth) * width;
const padY = (motifPadding / motifHeight) * height;
const scale = width / 400;
const nodeRadius = 4.5 * scale;

// Pull every node 20% closer to the plot's center, so the graph reads as
// slightly more compact/clustered without changing the canvas or the
// triangulation's proportions (still an affine transform, so it stays
// planar — see the note above).
const spacingScale = 0.8;
const centerX = width / 2;
const centerY = height / 2;

const nodes = CONTENT_POINTS.map((p) => {
  const rawX = padX + p.topic * (width - padX * 2);
  const rawY = padY + (1 - p.recency) * (height - padY * 2);
  return {
    slug: p.slug,
    title: p.title,
    // Research/project/experience cards all live on the homepage, so an
    // on-page anchor works regardless of each point's own `href` (which for
    // projects points offsite to the repo instead). Coursework cards live on
    // a separate page, so those nodes need the real cross-page href.
    href: p.kind === "coursework" ? p.href : `#content-${p.slug}`,
    x: centerX + (rawX - centerX) * spacingScale,
    y: centerY + (rawY - centerY) * spacingScale,
  };
});
const nodeBySlug = new Map(nodes.map((n) => [n.slug, n]));

const graph = buildAdjacency(
  CONTENT_POINTS.map((p) => p.slug),
  slugEdges,
);
const seeds = findMinimumZeroForcingSet(graph);
const forcing = simulateForcing(graph, seeds);

const renderEdges = slugEdges.map(([a, b], index) => {
  const forceA = forcing.get(a);
  const forceB = forcing.get(b);
  const forcingRound = forceA?.via === b ? forceA.round : forceB?.via === a ? forceB.round : null;
  return { from: nodeBySlug.get(a)!, to: nodeBySlug.get(b)!, index, forcingRound };
});

const renderNodes = nodes.map((node) => ({
  node,
  round: forcing.get(node.slug)?.round ?? 0,
}));

// Longer than any possible edge, so the draw-in stroke-dasharray always
// covers the full line regardless of canvas size.
const edgeDash = Math.ceil(Math.hypot(width, height));

// Estimate a monospace label's rendered width and clamp its centered x so it
// never overflows the viewBox — titles vary a lot in length ("quire" vs.
// "Zero Forcing Polytopes (research)"), so a fixed edge margin isn't enough.
// Font size is intentionally not tied to `scale` (that's for node/stroke
// weight) — a small caption-sized label reads as a tooltip, a `scale`d one
// reads as a second heading.
const labelFontSize = 13;
const estCharWidth = labelFontSize * 0.62;
const labelSafeMargin = 16;
function clampLabelX(centerX: number, title: string): number {
  const halfWidth = (title.length * estCharWidth) / 2;
  const min = labelSafeMargin + halfWidth;
  const max = width - labelSafeMargin - halfWidth;
  if (min > max) return width / 2;
  return Math.min(Math.max(centerX, min), max);
}
---

<div class="zf-hero-wrap">
  <svg class="zf-hero w-full h-auto" viewBox={`0 0 ${width} ${height}`} fill="none" aria-hidden="true" focusable="false">
    {
      renderEdges.map(({ from, to, index, forcingRound }) => (
        <line
          class:list={["zf-edge", forcingRound !== null && "zf-forcing"]}
          style={{
            "--i": index,
            ...(forcingRound !== null ? { "--round": forcingRound } : {}),
          }}
          x1={from.x}
          y1={from.y}
          x2={to.x}
          y2={to.y}
        />
      ))
    }

    {
      renderNodes.map(({ node, round }) => {
        // Flip the label below the node when it's near the top edge so the
        // halo text doesn't clip against the viewBox boundary.
        const labelBelow = node.y - padY < 24;
        const labelY = labelBelow ? node.y + 20 : node.y - 14;
        const labelX = clampLabelX(node.x, node.title);
        return (
          <a href={node.href} class="zf-node-link" tabindex="-1">
            <circle
              class:list={["zf-node", round === 0 ? "zf-seed" : "zf-forced"]}
              style={{ "--round": round }}
              cx={node.x}
              cy={node.y}
              r={nodeRadius}
            />
            <text x={labelX} y={labelY} text-anchor="middle" class="zf-node-label zf-node-label-halo" aria-hidden="true">
              {node.title}
            </text>
            <text x={labelX} y={labelY} text-anchor="middle" class="zf-node-label" aria-hidden="true">
              {node.title}
            </text>
            <title>{node.title}</title>
          </a>
        );
      })
    }
  </svg>

  <p class="zf-hero-caption font-mono text-xs text-stone">
    {copy("home.hero.zeroForcingCaptionPrefix")} <a href="/how-it-works#zero-forcing" class="text-moss hover:text-parchment transition-colors duration-150">{copy("home.hero.zeroForcingCaptionLink")}</a>
  </p>

  <ul class="sr-only">
    {
      nodes.map((node) => (
        <li>
          <a href={node.href}>{node.title}</a>
        </li>
      ))
    }
  </ul>
</div>

<script>
  // SVG has no z-index — paint order is DOM order, so a later node's circle
  // can draw over an earlier node's tooltip label. Bump the hovered/focused
  // node to the end of its parent so its label always paints on top.
  document.querySelectorAll<SVGAElement>(".zf-hero .zf-node-link").forEach((link) => {
    const raise = () => link.parentElement?.appendChild(link);
    link.addEventListener("pointerenter", raise);
    link.addEventListener("focus", raise);
  });
</script>

<style define:vars={{ scale, edgeDash, labelFontSize }}>
  .zf-hero {
    overflow: visible;
  }

  .zf-edge {
    stroke: var(--color-stone);
    stroke-width: calc(1.5 * var(--scale));
    stroke-linecap: round;
    stroke-dasharray: var(--edgeDash);
    stroke-dashoffset: var(--edgeDash);
    animation: zf-draw var(--duration-base) var(--ease-field) forwards;
    animation-delay: calc(var(--i) * var(--duration-stagger) / 5);
  }

  .zf-edge.zf-forcing {
    animation:
      zf-draw var(--duration-base) var(--ease-field) forwards,
      zf-pulse var(--duration-base) var(--ease-field) forwards;
    animation-delay:
      calc(var(--i) * var(--duration-stagger) / 5),
      calc(var(--round) * var(--duration-stagger) - 60ms);
  }

  .zf-node-link {
    cursor: pointer;
  }

  .zf-node {
    stroke: var(--color-stone);
    stroke-width: calc(1.5 * var(--scale));
    fill: var(--color-canopy);
    transform-box: fill-box;
    transform-origin: center;
    transition:
      transform 150ms var(--ease-field),
      filter 150ms var(--ease-field);
  }

  .zf-seed {
    fill: var(--color-moss);
  }

  .zf-forced {
    animation: zf-force var(--duration-base) var(--ease-field) forwards;
    animation-delay: calc(var(--round) * var(--duration-stagger));
  }

  .zf-node-link:hover .zf-node,
  .zf-node-link:focus-visible .zf-node {
    transform: scale(1.4);
    stroke: var(--color-moss);
    filter: drop-shadow(0 0 calc(4px * var(--scale)) color-mix(in srgb, var(--color-moss) 55%, transparent));
  }

  .zf-node-label,
  .zf-node-label-halo {
    font-family: var(--font-mono);
    font-size: calc(var(--labelFontSize) * 1px);
    pointer-events: none;
    opacity: 0;
    transition: opacity 150ms var(--ease-field);
  }

  .zf-node-label {
    fill: var(--color-parchment);
  }

  .zf-node-label-halo {
    fill: none;
    stroke: var(--color-canopy);
    stroke-width: 3px;
    stroke-linejoin: round;
    paint-order: stroke;
  }

  .zf-node-link:hover .zf-node-label,
  .zf-node-link:hover .zf-node-label-halo,
  .zf-node-link:focus-visible .zf-node-label,
  .zf-node-link:focus-visible .zf-node-label-halo {
    opacity: 1;
  }

  .zf-hero-caption {
    margin-top: 0.5rem;
  }

  @keyframes zf-draw {
    to {
      stroke-dashoffset: 0;
    }
  }

  @keyframes zf-force {
    to {
      fill: var(--color-moss);
    }
  }

  @keyframes zf-pulse {
    0% {
      stroke: var(--color-stone);
    }
    50% {
      stroke: var(--color-moss);
      stroke-width: calc(2.5 * var(--scale));
    }
    100% {
      stroke: var(--color-stone);
      stroke-width: calc(1.5 * var(--scale));
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .zf-edge,
    .zf-edge.zf-forcing,
    .zf-forced {
      animation-duration: 0s !important;
      animation-delay: 0s !important;
    }

    .zf-node-link:hover .zf-node,
    .zf-node-link:focus-visible .zf-node {
      transform: none;
    }
  }
</style>
