---
interface EmailRail {
  variant: "email";
  email: string;
}

interface SocialRail {
  variant: "social";
  links: { label: string; href: string }[];
  personalSite: { label: string; href: string };
}

type Props = (EmailRail | SocialRail) & { orientation: "left" | "right" };

const props = Astro.props;
const { orientation } = props;
---

<div class={`side-rail side-rail--${orientation} hidden lg:flex fixed bottom-0 z-10 flex-col items-center gap-6`}>
  {
    props.variant === "email" ? (
      <a
        href={`mailto:${props.email}`}
        class="side-rail-email font-mono text-xs tracking-widest text-stone hover:text-moss hover:-translate-y-1 transition-all duration-150"
      >
        {props.email}
      </a>
    ) : (
      <ul class="flex flex-col items-center gap-5">
        {props.links.map((link) => (
          <li>
            <a
              href={link.href}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={link.label}
              class="text-stone hover:text-moss hover:-translate-y-1 transition-all duration-150 inline-block"
            >
              <span class="font-mono text-[0.65rem] tracking-widest">{link.label}</span>
            </a>
          </li>
        ))}
        <li>
          <button
            type="button"
            id="resume-trigger"
            class="text-stone hover:text-moss hover:-translate-y-1 transition-all duration-150 inline-block cursor-pointer font-mono text-[0.65rem] tracking-widest"
          >
            Resume
          </button>
        </li>
        <li class="flex flex-col items-center gap-2">
          <span class="side-rail-dot transition-colors duration-150" aria-hidden="true">&middot;</span>
          <a
            href={props.personalSite.href}
            aria-label={props.personalSite.label}
            class="text-stone hover:text-moss hover:-translate-y-1 transition-all duration-150 inline-block"
          >
            <span class="font-mono text-[0.65rem] tracking-widest">{props.personalSite.label}</span>
          </a>
        </li>
      </ul>
    )
  }
  <span class="side-rail-line w-px h-24 bg-bark" aria-hidden="true"></span>
</div>

<style>
  .side-rail {
    padding-bottom: 0;
  }
  .side-rail--left {
    left: 2.5rem;
  }
  .side-rail--right {
    right: 2.5rem;
  }
  .side-rail-email {
    writing-mode: vertical-rl;
  }
  .side-rail-dot:hover {
    color: var(--color-lavender);
  }
  @media (max-width: 1400px) {
    .side-rail--left {
      left: 1.25rem;
    }
    .side-rail--right {
      right: 1.25rem;
    }
  }
</style>
