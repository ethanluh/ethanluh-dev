---
interface EmailRail {
  variant: "email";
  email: string;
}

interface SocialRail {
  variant: "social";
  links: { label: string; href: string }[];
  personalSite: { label: string; href: string };
}

type Props = (EmailRail | SocialRail) & { orientation: "left" | "right"; themeToggle?: boolean };

const props = Astro.props;
const { orientation, themeToggle } = props;
---

<div class={`side-rail side-rail--${orientation} hidden lg:flex fixed bottom-0 z-10 flex-col items-center gap-6`}>
  {
    props.variant === "email" ? (
      <a
        href={`mailto:${props.email}`}
        class="side-rail-email font-mono text-xs tracking-widest text-stone hover:text-moss hover:-translate-y-1 transition-all duration-150 p-2 -m-2"
      >
        {props.email}
      </a>
    ) : (
      <ul class="flex flex-col items-center gap-5">
        {props.links.map((link) => (
          <li>
            <a
              href={link.href}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={link.label}
              class="text-stone hover:text-moss hover:-translate-y-1 transition-all duration-150 inline-block p-2 -m-2"
            >
              <span class="font-mono text-[0.65rem] tracking-widest">{link.label}</span>
            </a>
          </li>
        ))}
        <li>
          <button
            type="button"
            id="resume-trigger"
            class="text-stone hover:text-moss hover:-translate-y-1 transition-all duration-150 inline-block cursor-pointer font-mono text-[0.65rem] tracking-widest p-2 -m-2"
          >
            Resume
          </button>
        </li>
        <li class="flex flex-col items-center gap-2">
          <span class="side-rail-dot transition-colors duration-150" aria-hidden="true">&middot;</span>
          <a
            href={props.personalSite.href}
            aria-label={props.personalSite.label}
            class="text-stone hover:text-moss hover:-translate-y-1 transition-all duration-150 inline-block p-2 -m-2"
          >
            <span class="font-mono text-[0.65rem] tracking-widest">{props.personalSite.label}</span>
          </a>
        </li>
      </ul>
    )
  }
  {
    themeToggle ? (
      <button id="theme-toggle" type="button" role="switch" aria-checked="false" aria-label="Toggle color theme" class="theme-toggle">
        <span class="theme-toggle-track">
          <span class="theme-toggle-thumb">
            <span class="theme-toggle-icon" aria-hidden="true">
              ☾
            </span>
          </span>
        </span>
      </button>
    ) : (
      <span class="side-rail-line w-px h-24 bg-bark" aria-hidden="true" />
    )
  }
</div>

<style>
  .side-rail {
    padding-bottom: 0;
  }
  .side-rail--left {
    left: 2.5rem;
  }
  .side-rail--right {
    right: 2.5rem;
  }
  .side-rail-email {
    writing-mode: vertical-rl;
  }
  .side-rail-dot:hover {
    color: var(--color-lavender);
  }
  @media (max-width: 1400px) {
    .side-rail--left {
      left: 1.25rem;
    }
    .side-rail--right {
      right: 1.25rem;
    }
  }

  .theme-toggle {
    display: inline-flex;
    justify-content: center;
    padding: 0;
    border: none;
    background: none;
    cursor: pointer;
  }
  .theme-toggle:focus:not(:focus-visible) {
    outline: none;
  }

  .theme-toggle-track {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 1.2rem;
    height: 6rem;
  }

  .theme-toggle-track::before {
    content: "";
    position: absolute;
    top: 0;
    bottom: 0;
    left: 50%;
    width: 1px;
    background-color: var(--color-bark);
    transform: translateX(-50%);
    transition: background-color var(--duration-base) var(--ease-field);
  }

  .theme-toggle-thumb {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    box-sizing: border-box;
    width: 0.9rem;
    height: 0.9rem;
    border: 1.5px solid var(--color-moss);
    border-radius: 50%;
    background-color: var(--surface-light);
    color: var(--surface-dark);
    font-size: 0.55rem;
    line-height: 1;
    transform: translateY(-0.6rem);
    transition:
      transform var(--duration-base) var(--ease-field),
      background-color var(--duration-base) var(--ease-field),
      color var(--duration-base) var(--ease-field),
      border-color var(--duration-base) var(--ease-field);
  }

  .theme-toggle[aria-checked="true"] .theme-toggle-thumb {
    background-color: var(--surface-dark);
    color: var(--surface-light);
    transform: translateY(0.6rem);
  }

  .theme-toggle:hover .theme-toggle-track::before {
    background-color: var(--color-moss);
  }
</style>

<script>
  const themeToggle = document.getElementById("theme-toggle");
  const themeIcon = themeToggle?.querySelector(".theme-toggle-icon");
  const lightScheme = window.matchMedia("(prefers-color-scheme: light)");

  function currentTheme(): "light" | "dark" {
    const explicit = document.documentElement.dataset.theme;
    if (explicit === "light" || explicit === "dark") return explicit;
    return lightScheme.matches ? "light" : "dark";
  }

  function applyIcon(theme: "light" | "dark") {
    if (themeIcon) themeIcon.textContent = theme === "dark" ? "☾" : "☀";
    themeToggle?.setAttribute("aria-checked", theme === "light" ? "true" : "false");
  }

  applyIcon(currentTheme());

  themeToggle?.addEventListener("click", () => {
    const next = currentTheme() === "dark" ? "light" : "dark";
    document.documentElement.dataset.theme = next;
    localStorage.setItem("theme", next);
    applyIcon(next);
  });

  lightScheme.addEventListener("change", () => {
    if (!localStorage.getItem("theme")) applyIcon(currentTheme());
  });
</script>
