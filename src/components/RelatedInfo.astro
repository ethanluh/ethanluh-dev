---
import DelaunayMotif from "./DelaunayMotif.astro";

interface DelaunayPoint {
  slug: string;
  title: string;
  topic: number;
  recency: number;
}

interface Props {
  related: { title: string; href: string }[];
  delaunay: { points: DelaunayPoint[]; edges: [number, number][]; activeSlug: string };
}

const { related, delaunay } = Astro.props;
---

{
  related.length > 0 && (
    <span class="related-info">
      <button type="button" class="related-trigger tap-target font-mono text-xs" aria-expanded="false">
        ⓘ {related.length} related
      </button>
      <span class="related-popover" role="note">
        <span class="related-popover-graph">
          <DelaunayMotif
            points={delaunay.points}
            edges={delaunay.edges}
            activeSlug={delaunay.activeSlug}
            width={220}
            height={150}
          />
          <span class="related-popover-title font-mono text-[0.65rem] uppercase tracking-widest text-stone">
            Delaunay neighbors
          </span>
        </span>
        <span class="related-links font-mono text-xs">
          {related.map((r) => (
            <a href={r.href} class="related-link text-moss hover:text-parchment transition-colors duration-150">
              {r.title}
            </a>
          ))}
        </span>
      </span>
    </span>
  )
}

<style>
  .related-info {
    position: relative;
    display: inline-flex;
  }
  .related-trigger {
    background: none;
    border: none;
    padding-inline: 0;
    color: var(--color-stone);
    border-bottom: 1px dotted var(--color-stone);
    cursor: help;
    transition: color var(--ease-field) 150ms, border-color var(--ease-field) 150ms;
  }
  .related-trigger:hover,
  .related-trigger:focus-visible {
    color: var(--color-moss);
    border-color: var(--color-moss);
  }
  .related-popover {
    position: absolute;
    z-index: 20;
    bottom: calc(100% + 8px);
    left: 0;
    display: flex;
    flex-direction: row;
    align-items: flex-start;
    gap: 0.75rem;
    width: max-content;
    max-width: min(480px, calc(100vw - 2rem));
    padding: 0.75rem;
    background: var(--color-canopy);
    border: 1px solid color-mix(in srgb, var(--color-moss) 30%, transparent);
    border-radius: 0.25rem;
    box-shadow: 0 12px 24px -12px rgb(0 0 0 / 0.5);
    opacity: 0;
    pointer-events: none;
    transition: opacity 160ms var(--ease-field);
  }
  .related-popover-graph {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    flex-shrink: 0;
  }
  .related-links {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    padding-top: 0.6rem;
  }
  .related-link {
    white-space: normal;
  }
  .related-info:hover .related-popover,
  .related-info:focus-within .related-popover,
  .related-info.open .related-popover {
    opacity: 1;
    pointer-events: auto;
  }
  @media (prefers-reduced-motion: no-preference) {
    .related-popover {
      transform: translateY(4px);
      transition:
        opacity 160ms var(--ease-field),
        transform 160ms var(--ease-field);
    }
    .related-info:hover .related-popover,
    .related-info:focus-within .related-popover,
    .related-info.open .related-popover {
      transform: translateY(0);
    }
  }

  /* Anchoring the popover to the trigger's left edge overflows the viewport
     when a card's trigger sits away from the screen's left edge, and
     position: fixed doesn't reliably escape it — the card's own
     hover/focus transform (.card-lift) creates a containing block that
     traps fixed-position descendants too. Drop the floating overlay in
     favor of an in-flow panel below the trigger instead. Raised to 1024px:
     the floating popover was still overflowing the viewport at narrower
     desktop/tablet widths (measured 183px of overflow at 1023px). */
  @media (max-width: 1024px) {
    .related-info {
      display: block;
    }
    .related-popover {
      position: static;
      display: none;
      opacity: 1;
      pointer-events: auto;
      flex-wrap: wrap;
      width: 100%;
      max-width: none;
      margin-top: 0.5rem;
      transform: none;
    }
    .related-info:hover .related-popover,
    .related-info:focus-within .related-popover,
    .related-info.open .related-popover {
      display: flex;
      transform: none;
    }
  }
</style>

<script>
  // :hover/:focus-within alone don't reliably trigger on iOS Safari taps, so
  // give the trigger an explicit click-toggle too. Hover/focus keep working
  // as-is via the CSS above; this just adds a third way in — but the
  // attribute is driven from a single function on every relevant event
  // (click, hover, focus) so aria-expanded never contradicts the visible
  // (CSS hover/focus-within) state.
  const allInfos = document.querySelectorAll<HTMLElement>(".related-info");

  function isVisiblyOpen(info: HTMLElement) {
    return info.classList.contains("open") || info.matches(":hover") || info.matches(":focus-within");
  }

  function syncExpanded(info: HTMLElement) {
    const trigger = info.querySelector<HTMLButtonElement>(".related-trigger");
    trigger?.setAttribute("aria-expanded", String(isVisiblyOpen(info)));
  }

  allInfos.forEach((info) => {
    const trigger = info.querySelector<HTMLButtonElement>(".related-trigger");
    if (!trigger) return;

    trigger.addEventListener("click", (event) => {
      event.stopPropagation();
      const opening = !info.classList.contains("open");
      if (opening) {
        allInfos.forEach((other) => {
          if (other !== info) {
            other.classList.remove("open");
            syncExpanded(other);
          }
        });
      }
      info.classList.toggle("open", opening);
      syncExpanded(info);
    });

    info.addEventListener("focusin", () => syncExpanded(info));
    info.addEventListener("mouseenter", () => syncExpanded(info));
    info.addEventListener("mouseleave", () => syncExpanded(info));
    info.addEventListener("focusout", () => syncExpanded(info));
  });

  document.addEventListener("click", (event) => {
    allInfos.forEach((info) => {
      if (!info.contains(event.target as Node) && info.classList.contains("open")) {
        info.classList.remove("open");
        syncExpanded(info);
      }
    });
  });

  document.addEventListener("keydown", (event) => {
    if (event.key !== "Escape") return;
    allInfos.forEach((info) => {
      if (info.classList.contains("open")) {
        info.classList.remove("open");
        syncExpanded(info);
      }
    });
  });
</script>
