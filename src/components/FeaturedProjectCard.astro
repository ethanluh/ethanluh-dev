---
import RelatedInfo from "./RelatedInfo.astro";

interface DelaunayPoint {
  slug: string;
  title: string;
  topic: number;
  recency: number;
}

interface Props {
  id?: string;
  number: string;
  title: string;
  tag: string;
  description: string;
  impact?: string;
  href?: string;
  links?: { label: string; href: string }[];
  image?: string;
  imageAlt?: string;
  kindLabel?: string;
  eyebrow?: string;
  statusKind?: "live" | "shipped" | "inProgress";
  statusLabel?: string;
  rankReason?: string;
  related?: { title: string; href: string }[];
  delaunay?: { points: DelaunayPoint[]; edges: [number, number][]; activeSlug: string };
  techStack?: string[];
  mathStack?: string[];
}

const {
  id,
  number,
  title,
  tag,
  description,
  impact,
  href,
  links: linksProp,
  image,
  imageAlt,
  kindLabel,
  eyebrow,
  statusKind,
  statusLabel,
  rankReason,
  related = [],
  delaunay,
  techStack = [],
  mathStack = [],
} = Astro.props;
const tags = tag.split(" · ");
const links = linksProp ?? (href ? [{ label: "view", href }] : []);
const imageHref = links[0]?.href ?? href;
const hasDetails = description.length > 160 || links.length > 0;
---

<article
  id={id}
  class:list={[
    "featured-specimen card-lift bg-bark/40 border border-moss/30 rounded-sm p-9 sm:p-12 shadow-lg shadow-canopy/40 grid grid-cols-1 gap-8 scroll-mt-24",
    image ? "sm:grid-cols-[3fr_2fr] sm:items-center" : "",
  ]}
>
  <div class:list={["flex flex-col", !image && "max-w-prose"]}>
    <div class="meta-row flex flex-wrap items-center gap-x-2 gap-y-1 font-mono text-xs mb-3">
      <span class="uppercase tracking-widest text-moss">{eyebrow ?? "featured"}{kindLabel && ` · ${kindLabel}`}</span>
      {rankReason && <span class="chip text-stone text-[0.7rem] normal-case tracking-normal">{rankReason}</span>}
      <span class="text-stone" aria-hidden="true">·</span>
      <span class="text-stone">no. {number}</span>
      {statusLabel && (
        <span class="chip text-stone">
          {statusKind === "live" && <span class="text-moss" aria-hidden="true">&#9679; </span>}
          {statusLabel}
        </span>
      )}
      {tags.map((entry) => (
        <span class="chip text-stone">{entry}</span>
      ))}
    </div>
    <div class="flex flex-col flex-1">
      <h3 class="font-display text-h3 mb-3 flex items-center gap-2">
        {title}
      </h3>
      {impact && <p class="text-parchment mb-1">{impact}</p>}
      <p class="text-parchment/90 mb-3">{description}</p>
      {
        techStack.length > 0 && (
          <p class="stack-row font-mono text-[0.65rem] uppercase tracking-widest text-stone mb-1">
            <span class="text-moss">tech</span> {techStack.join(" · ")}
          </p>
        )
      }
      {
        mathStack.length > 0 && (
          <p class="stack-row font-mono text-[0.65rem] uppercase tracking-widest text-stone mb-2">
            <span class="text-moss">math</span> {mathStack.join(" · ")}
          </p>
        )
      }
      {
        hasDetails && (
          <button
            type="button"
            class="details-trigger tap-target font-mono text-xs text-moss hover:text-parchment transition-colors duration-150 mb-3 self-start"
            aria-haspopup="dialog"
            data-number={number}
            data-title={title}
            data-tag={tag}
            data-kind-label={kindLabel ? `Featured · ${kindLabel}` : "Featured"}
            data-description={description}
            data-links={JSON.stringify(links)}
            data-tech-stack={JSON.stringify(techStack)}
            data-math-stack={JSON.stringify(mathStack)}
          >
            details &rarr;
          </button>
        )
      }
      {
        delaunay && (
          <div class="mt-auto pt-2">
            <RelatedInfo related={related} delaunay={delaunay} />
          </div>
        )
      }
    </div>
  </div>
  {
    image && (
      <a
        href={imageHref ?? "#"}
        class="featured-image-link relative block rounded-sm overflow-hidden"
        tabindex={imageHref ? 0 : -1}
        aria-hidden={imageHref ? undefined : "true"}
      >
        <img
          src={image}
          alt={imageAlt ?? ""}
          aria-hidden={imageAlt ? undefined : "true"}
          class="featured-image w-full h-auto block"
          loading="lazy"
        />
      </a>
    )
  }
</article>

<style>
  .card-lift {
    transition:
      transform var(--duration-base) var(--ease-field),
      box-shadow var(--duration-base) var(--ease-field);
  }
  @media (prefers-reduced-motion: no-preference) {
    .card-lift:hover,
    .card-lift:focus-within {
      transform: translateY(-4px);
      box-shadow: 0 12px 24px -12px rgb(0 0 0 / 0.5);
    }
  }
  .featured-image-link {
    background-color: var(--color-canopy);
  }
  .featured-image-link::before {
    content: "";
    position: absolute;
    inset: 0;
    background-color: var(--color-canopy);
    mix-blend-mode: screen;
    opacity: 0.4;
    transition: opacity var(--duration-base) var(--ease-field);
    z-index: 1;
  }
  .featured-image {
    filter: grayscale(100%) contrast(1) brightness(90%);
    transition: filter var(--duration-base) var(--ease-field);
  }
  .featured-image-link:hover::before,
  .featured-image-link:focus-visible::before {
    opacity: 0;
  }
  .featured-image-link:hover .featured-image,
  .featured-image-link:focus-visible .featured-image {
    filter: none;
  }
</style>
