---
interface Props {
  number: string;
  title: string;
  tag: string;
  description: string;
  href: string;
}

const { number, title, tag, description, href } = Astro.props;
---

<article class="featured-specimen bg-bark border border-moss/30 border-l-[3px] border-l-moss rounded-r-sm p-9 sm:p-10 shadow-lg shadow-canopy/40 flex flex-col sm:flex-row gap-6 sm:items-baseline">
  <div class="font-mono text-lg text-parchment shrink-0">
    {number}
  </div>
  <div>
    <p class="font-mono text-xs uppercase tracking-widest text-moss mb-2">Featured</p>
    <h3 class="font-display text-2xl mb-2">{title}</h3>
    <p class="font-mono text-xs text-stone mb-3">{tag}</p>
    <p class="text-parchment/90 mb-3">{description}</p>
    <div class="flex gap-4 font-mono text-xs">
      <a href={href} class="text-moss hover:text-parchment transition-colors duration-150">view</a>
    </div>
  </div>
</article>
