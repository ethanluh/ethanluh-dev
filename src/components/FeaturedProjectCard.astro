---
import RelatedInfo from "./RelatedInfo.astro";

interface DelaunayPoint {
  slug: string;
  title: string;
  topic: number;
  recency: number;
}

interface Props {
  id?: string;
  number: string;
  title: string;
  tag: string;
  description: string;
  href?: string;
  links?: { label: string; href: string }[];
  image?: string;
  kindLabel?: string;
  eyebrow?: string;
  related?: { title: string; href: string }[];
  delaunay?: { points: DelaunayPoint[]; edges: [number, number][]; activeSlug: string };
}

const {
  id,
  number,
  title,
  tag,
  description,
  href,
  links: linksProp,
  image,
  kindLabel,
  eyebrow,
  related = [],
  delaunay,
} = Astro.props;
const tags = tag.split(" · ");
const links = linksProp ?? (href ? [{ label: "view", href }] : []);
const imageHref = links[0]?.href ?? href;
const hasDetails = description.length > 160 || links.length > 0;
---

<article id={id} class="featured-specimen card-lift bg-bark/40 border border-moss/30 rounded-sm p-9 sm:p-12 shadow-lg shadow-canopy/40 grid grid-cols-1 sm:grid-cols-[3fr_2fr] gap-8 sm:items-center scroll-mt-24">
  <div class="flex flex-col">
    <div class="meta-row flex flex-wrap items-center gap-x-2 gap-y-1 font-mono text-xs mb-3">
      <span class="font-display text-lg text-parchment mr-1">{number}</span>
      <span class="uppercase tracking-widest text-moss">{eyebrow ?? "Featured"}{kindLabel && ` · ${kindLabel}`}</span>
      <span class="text-stone" aria-hidden="true">·</span>
      {tags.map((entry) => (
        <span class="chip text-stone">{entry}</span>
      ))}
    </div>
    <div class="flex flex-col flex-1">
      <h3 class="font-display text-3xl mb-3 flex items-center gap-2">
        {title}
      </h3>
      <p class="text-parchment/90 mb-3">{description}</p>
      {
        hasDetails && (
          <button
            type="button"
            class="details-trigger font-mono text-xs text-moss hover:text-parchment transition-colors duration-150 mb-3 self-start"
            aria-haspopup="dialog"
            data-number={number}
            data-title={title}
            data-tag={tag}
            data-kind-label={kindLabel ? `Featured · ${kindLabel}` : "Featured"}
            data-description={description}
            data-links={JSON.stringify(links)}
          >
            details &rarr;
          </button>
        )
      }
      {
        delaunay && (
          <div class="mt-auto pt-2">
            <RelatedInfo related={related} delaunay={delaunay} />
          </div>
        )
      }
    </div>
  </div>
  {
    image && (
      <a
        href={imageHref ?? "#"}
        class="featured-image-link relative block rounded-sm overflow-hidden"
        tabindex={imageHref ? 0 : -1}
        aria-hidden={imageHref ? undefined : "true"}
      >
        <img src={image} alt="" class="featured-image w-full h-auto block" loading="lazy" />
      </a>
    )
  }
</article>

<style>
  .card-lift {
    transition:
      transform var(--duration-base) var(--ease-field),
      box-shadow var(--duration-base) var(--ease-field);
  }
  @media (prefers-reduced-motion: no-preference) {
    .card-lift:hover,
    .card-lift:focus-within {
      transform: translateY(-4px);
      box-shadow: 0 12px 24px -12px rgb(0 0 0 / 0.5);
    }
  }
  .featured-image-link {
    background-color: var(--color-canopy);
  }
  .featured-image-link::before {
    content: "";
    position: absolute;
    inset: 0;
    background-color: var(--color-canopy);
    mix-blend-mode: screen;
    transition: opacity var(--duration-base) var(--ease-field);
    z-index: 1;
  }
  .featured-image {
    filter: grayscale(100%) contrast(1) brightness(90%);
    transition: filter var(--duration-base) var(--ease-field);
  }
  .featured-image-link:hover::before,
  .featured-image-link:focus-visible::before {
    opacity: 0;
  }
  .featured-image-link:hover .featured-image,
  .featured-image-link:focus-visible .featured-image {
    filter: none;
  }
</style>
