<dialog id="resume-modal" class="resume-modal" aria-labelledby="resume-modal-title">
  <div class="flex items-center justify-between gap-4 border-b border-bark px-5 py-3">
    <h2 id="resume-modal-title" class="font-mono text-xs uppercase tracking-widest text-stone">
      Résumé
    </h2>
    <div class="flex items-center gap-4 font-mono text-xs">
      <a href="/resume.pdf" download class="hover:text-parchment transition-colors duration-150"> Download </a>
      <a href="/resume.tex" download class="hover:text-parchment transition-colors duration-150"> LaTeX Source </a>
      <button
        type="button"
        id="resume-modal-close"
        aria-label="Close resume"
        class="hover:text-parchment transition-colors duration-150 cursor-pointer text-base leading-none"
      >
        &times;
      </button>
    </div>
  </div>
  <div id="resume-modal-body" class="resume-modal-object">
    <p class="p-6 font-mono text-xs text-stone">
      Loading résumé…
    </p>
  </div>
</dialog>

<style>
  .resume-modal {
    box-sizing: border-box;
    margin: auto;
    padding: 0;
    width: min(90vw, 900px);
    max-width: 90vw;
    min-width: 320px;
    height: 90vh;
    border: 1px solid var(--color-bark);
    background-color: var(--color-canopy);
    color: var(--color-parchment);
  }

  .resume-modal[open] {
    display: flex;
    flex-direction: column;
  }

  .resume-modal[open].resume-modal--sizing {
    visibility: hidden;
  }

  .resume-modal::backdrop {
    background-color: rgb(0 0 0 / 0.6);
  }

  .resume-modal-object {
    flex: 1;
    width: 100%;
    min-height: 0;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0;
    padding: 0;
  }

  .resume-modal-object :global(canvas) {
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
    box-shadow: 0 1px 4px rgb(0 0 0 / 0.3);
  }
</style>

<script>
  import * as pdfjsLib from "pdfjs-dist";
  import pdfWorkerUrl from "pdfjs-dist/build/pdf.worker.min.mjs?url";

  pdfjsLib.GlobalWorkerOptions.workerSrc = pdfWorkerUrl;

  const trigger = document.getElementById("resume-trigger");
  const modal = document.getElementById("resume-modal") as HTMLDialogElement | null;
  const closeBtn = document.getElementById("resume-modal-close");
  const body = document.getElementById("resume-modal-body");

  let rendered = false;

  async function renderResume() {
    if (rendered || !body) return;
    rendered = true;

    try {
      const pdf = await pdfjsLib.getDocument("/resume.pdf").promise;
      body.innerHTML = "";

      for (let pageNum = 1; pageNum <= pdf.numPages; pageNum++) {
        const page = await pdf.getPage(pageNum);
        const scale = (window.devicePixelRatio || 1) * 1.5;
        const viewport = page.getViewport({ scale });

        const canvas = document.createElement("canvas");
        canvas.width = viewport.width;
        canvas.height = viewport.height;
        const context = canvas.getContext("2d");
        if (!context) continue;

        await page.render({ canvas, canvasContext: context, viewport }).promise;
        body.appendChild(canvas);
      }
    } catch {
      rendered = false;
      body.innerHTML = `<p class="p-6 font-mono text-xs text-stone">Couldn't render the résumé. <a href="/resume.pdf" download class="text-parchment underline">Download it</a> instead.</p>`;
    }
  }

  function fitModalWidth() {
    return new Promise<void>((resolve) => {
      const canvas = body?.querySelector("canvas");
      if (!canvas || !modal) {
        resolve();
        return;
      }
      requestAnimationFrame(() => {
        const width = canvas.getBoundingClientRect().width;
        if (width > 0) modal.style.width = `${Math.ceil(width)}px`;
        resolve();
      });
    });
  }

  trigger?.addEventListener("click", async () => {
    modal?.classList.add("resume-modal--sizing");
    modal?.showModal();
    await renderResume();
    await fitModalWidth();
    modal?.classList.remove("resume-modal--sizing");
  });
  closeBtn?.addEventListener("click", () => modal?.close());
  modal?.addEventListener("click", (event) => {
    if (event.target === modal) modal.close();
  });
  window.addEventListener("resize", () => {
    if (modal?.open) fitModalWidth();
  });
</script>
