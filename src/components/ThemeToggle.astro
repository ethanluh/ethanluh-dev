---
---

<button type="button" role="switch" aria-checked="false" aria-label="Toggle color theme" data-theme-toggle class="theme-toggle self-start">
  <span class="theme-toggle-track">
    <span class="theme-toggle-thumb">
      <span class="theme-toggle-icon" aria-hidden="true">☾</span>
    </span>
  </span>
  <span class="font-mono text-[0.65rem] uppercase tracking-widest text-stone">Theme</span>
</button>

<style>
  .theme-toggle {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0;
    border: none;
    background: none;
    cursor: pointer;
  }
  .theme-toggle:focus:not(:focus-visible) {
    outline: none;
  }

  .theme-toggle-track {
    position: relative;
    display: flex;
    align-items: center;
    width: 2.2rem;
    height: 1.1rem;
    border-radius: 999px;
    border: 1px solid var(--color-bark);
    transition: border-color var(--duration-base) var(--ease-field);
  }

  .theme-toggle-thumb {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    box-sizing: border-box;
    width: 0.9rem;
    height: 0.9rem;
    margin-left: 0.05rem;
    border: 1.5px solid var(--color-moss);
    border-radius: 50%;
    background-color: var(--surface-light);
    color: var(--surface-dark);
    font-size: 0.55rem;
    line-height: 1;
    transform: translateX(0);
    transition:
      transform var(--duration-base) var(--ease-field),
      background-color var(--duration-base) var(--ease-field),
      color var(--duration-base) var(--ease-field);
  }

  .theme-toggle[aria-checked="true"] .theme-toggle-thumb {
    background-color: var(--surface-dark);
    color: var(--surface-light);
    transform: translateX(1rem);
  }

  .theme-toggle:hover .theme-toggle-track {
    border-color: var(--color-moss);
  }
</style>

<script>
  const themeToggles = document.querySelectorAll<HTMLButtonElement>("[data-theme-toggle]");
  const lightScheme = window.matchMedia("(prefers-color-scheme: light)");

  function currentTheme(): "light" | "dark" {
    const explicit = document.documentElement.dataset.theme;
    if (explicit === "light" || explicit === "dark") return explicit;
    return lightScheme.matches ? "light" : "dark";
  }

  function applyIcon(theme: "light" | "dark") {
    themeToggles.forEach((toggle) => {
      const icon = toggle.querySelector(".theme-toggle-icon");
      if (icon) icon.textContent = theme === "dark" ? "☾" : "☀";
      toggle.setAttribute("aria-checked", theme === "light" ? "true" : "false");
    });
  }

  applyIcon(currentTheme());

  themeToggles.forEach((toggle) => {
    toggle.addEventListener("click", () => {
      const next = currentTheme() === "dark" ? "light" : "dark";
      document.documentElement.dataset.theme = next;
      localStorage.setItem("theme", next);
      applyIcon(next);
    });
  });

  lightScheme.addEventListener("change", () => {
    if (!localStorage.getItem("theme")) applyIcon(currentTheme());
  });
</script>
