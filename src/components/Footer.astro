---
const GITHUB_URL = "https://github.com/ethanluh";
const CONTACT_EMAIL = "ethan@ethanluh.com";
const PERSONAL_SITE_URL = "https://me.ethanluh.com";
---

<footer id="contact" class="border-t border-bark mt-16">
  <div class="max-w-3xl mx-auto px-6 py-8 font-mono text-xs text-stone flex flex-col gap-3">
    <div class="flex flex-wrap gap-4">
      <a href="/resume.pdf" class="hover:text-moss transition-colors duration-150">Resume</a>
      <span aria-hidden="true">·</span>
      <a href={GITHUB_URL} class="hover:text-moss transition-colors duration-150">GitHub</a>
      <span aria-hidden="true">·</span>
      <a href={`mailto:${CONTACT_EMAIL}`} class="hover:text-moss transition-colors duration-150">Contact</a>
    </div>
    <div>
      Ethan Luh
      <span class="footer-dot mx-1 transition-colors duration-150" aria-hidden="true">&middot;</span>
      <a href={PERSONAL_SITE_URL} class="hover:text-moss transition-colors duration-150">me</a>
    </div>
  </div>
</footer>

<style>
  .footer-dot:hover {
    color: var(--color-lavender);
  }
</style>
