---
const GITHUB_URL = "https://github.com/ethanluh";
const LINKEDIN_URL = "https://linkedin.com/in/ethanluh";
const CONTACT_EMAIL = "ethan@ethanluh.com";
const PERSONAL_SITE_URL = "https://me.ethanluh.com";
---

<footer id="contact" class="border-t border-bark mt-16">
  <div class="max-w-3xl mx-auto px-6 py-8 font-mono text-xs text-stone flex flex-col gap-3">
    <div class="flex flex-wrap gap-4">
      <button
        type="button"
        id="resume-trigger"
        class="hover:text-moss transition-colors duration-150 cursor-pointer"
      >
        Resume
      </button>
      <span aria-hidden="true">·</span>
      <a href={GITHUB_URL} class="hover:text-moss transition-colors duration-150">GitHub</a>
      <span aria-hidden="true">·</span>
      <a href={LINKEDIN_URL} class="hover:text-moss transition-colors duration-150">LinkedIn</a>
      <span aria-hidden="true">·</span>
      <a href={`mailto:${CONTACT_EMAIL}`} class="hover:text-moss transition-colors duration-150">Contact</a>
    </div>
    <div>
      Ethan Luh
      <span class="footer-dot mx-1 transition-colors duration-150" aria-hidden="true">&middot;</span>
      <a href={PERSONAL_SITE_URL} class="hover:text-moss transition-colors duration-150">me</a>
    </div>
  </div>
</footer>

<dialog id="resume-modal" class="resume-modal" aria-labelledby="resume-modal-title">
  <div class="flex items-center justify-between gap-4 border-b border-bark px-5 py-3">
    <h2 id="resume-modal-title" class="font-mono text-xs uppercase tracking-widest text-stone">
      Résumé
    </h2>
    <div class="flex items-center gap-4 font-mono text-xs">
      <a href="/resume.pdf" download class="hover:text-moss transition-colors duration-150"> Download </a>
      <a href="/resume.tex" download class="hover:text-moss transition-colors duration-150"> LaTeX Source </a>
      <button
        type="button"
        id="resume-modal-close"
        aria-label="Close resume"
        class="hover:text-moss transition-colors duration-150 cursor-pointer text-base leading-none"
      >
        &times;
      </button>
    </div>
  </div>
  <div id="resume-modal-body" class="resume-modal-object">
    <p class="p-6 font-mono text-xs text-stone">
      Loading résumé…
    </p>
  </div>
</dialog>

<style>
  .footer-dot:hover {
    color: var(--color-lavender);
  }

  .resume-modal {
    margin: auto;
    padding: 0;
    width: min(90vw, 900px);
    height: 90vh;
    border: 1px solid var(--color-bark);
    background-color: var(--color-canopy);
    color: var(--color-parchment);
  }

  .resume-modal[open] {
    display: flex;
    flex-direction: column;
  }

  .resume-modal::backdrop {
    background-color: rgb(0 0 0 / 0.6);
  }

  .resume-modal-object {
    flex: 1;
    width: 100%;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    padding: 12px;
    background-color: var(--color-stone, #ccc);
  }

  .resume-modal-object canvas {
    max-width: 100%;
    box-shadow: 0 2px 12px rgb(0 0 0 / 0.4);
  }
</style>

<script>
  import * as pdfjsLib from "pdfjs-dist";
  import pdfWorkerUrl from "pdfjs-dist/build/pdf.worker.min.mjs?url";

  pdfjsLib.GlobalWorkerOptions.workerSrc = pdfWorkerUrl;

  const trigger = document.getElementById("resume-trigger");
  const modal = document.getElementById("resume-modal") as HTMLDialogElement | null;
  const closeBtn = document.getElementById("resume-modal-close");
  const body = document.getElementById("resume-modal-body");

  let rendered = false;

  async function renderResume() {
    if (rendered || !body) return;
    rendered = true;

    try {
      const pdf = await pdfjsLib.getDocument("/resume.pdf").promise;
      body.innerHTML = "";

      for (let pageNum = 1; pageNum <= pdf.numPages; pageNum++) {
        const page = await pdf.getPage(pageNum);
        const scale = (window.devicePixelRatio || 1) * 1.5;
        const viewport = page.getViewport({ scale });

        const canvas = document.createElement("canvas");
        canvas.width = viewport.width;
        canvas.height = viewport.height;
        canvas.style.width = `${viewport.width / (window.devicePixelRatio || 1)}px`;
        const context = canvas.getContext("2d");
        if (!context) continue;

        await page.render({ canvas, canvasContext: context, viewport }).promise;
        body.appendChild(canvas);
      }
    } catch {
      rendered = false;
      body.innerHTML = `<p class="p-6 font-mono text-xs text-stone">Couldn't render the résumé. <a href="/resume.pdf" download class="text-moss underline">Download it</a> instead.</p>`;
    }
  }

  trigger?.addEventListener("click", () => {
    modal?.showModal();
    renderResume();
  });
  closeBtn?.addEventListener("click", () => modal?.close());
  modal?.addEventListener("click", (event) => {
    if (event.target === modal) modal.close();
  });
</script>
