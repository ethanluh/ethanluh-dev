---
import { peelLayers } from "../lib/geometry/hull";

interface Props {
  email: string;
  socialLinks: { label: string; href: string }[];
}

const { email, socialLinks } = Astro.props;

// Hand-judged (depth, recency) per section — how specialized/deep the
// content is, and how recently it was touched. Not content metadata, just
// site-structure weight. Same convexHull utility as the featured-project
// selector on the homepage (see index.astro colophon).
const links = [
  { label: "work", href: "#work", depth: 0.95, recency: 0.95 },
  { label: "coursework", href: "#coursework", depth: 0.3, recency: 0.5 },
  { label: "about", href: "#about", depth: 0.2, recency: 0.3 },
  { label: "contact", href: "mailto:ethan@ethanluh.com", depth: 0.1, recency: 0.2 },
];

const layers = peelLayers(links, (l) => [l.recency, l.depth]);
const layerIndexByLabel = new Map(
  layers.flatMap((layer, layerIndex) => layer.map((l) => [l.label, layerIndex] as const)),
);
---

<header id="site-header" class="border-b border-bark sticky top-0 z-20 bg-canopy/85 backdrop-blur">
  <nav
    class="max-w-3xl mx-auto flex flex-wrap items-center justify-between gap-2 px-6 py-3 font-mono text-xs uppercase tracking-widest"
  >
    <a href="/" class="flex flex-col leading-tight text-parchment/80 hover:text-moss transition-colors duration-150">
      <span>Ethan Luh</span>
      <span class="text-[0.65rem] tracking-normal normal-case text-stone">field notes from graph theory & code</span>
    </a>
    <ul class="nav-links flex gap-5 items-center">
      {
        links.map((link) => (
          <li class:list={{ "nav-inner-layer": (layerIndexByLabel.get(link.label) ?? 0) > 0 }}>
            <a href={link.href} class="text-stone hover:text-moss transition-colors duration-150">
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
  <div class="mobile-contact-bar lg:hidden flex items-center justify-center gap-5 border-t border-bark px-6 py-2 font-mono text-[0.65rem] tracking-widest uppercase text-stone">
    <a href={`mailto:${email}`} class="hover:text-moss transition-colors duration-150">Email</a>
    {socialLinks.map((link) => (
      <a href={link.href} target="_blank" rel="noopener noreferrer" class="hover:text-moss transition-colors duration-150">{link.label}</a>
    ))}
    <button type="button" data-resume-trigger class="hover:text-moss transition-colors duration-150 cursor-pointer">Resume</button>
  </div>
</header>

<style>
  #site-header {
    transition:
      transform var(--duration-base) var(--ease-field),
      box-shadow var(--duration-base) var(--ease-field);
  }
  #site-header.nav-hidden {
    transform: translateY(-100%);
  }
  #site-header.nav-scrolled {
    box-shadow: 0 4px 12px -6px rgb(0 0 0 / 0.4);
  }

  .nav-links {
    counter-reset: item;
  }
  .nav-links li {
    counter-increment: item;
  }
  .nav-links li a::before {
    content: "0" counter(item) ". ";
    color: var(--color-moss);
  }
  .nav-inner-layer a {
    opacity: 0.75;
  }
</style>

<script>
  const header = document.getElementById("site-header");
  const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  if (header && !prefersReducedMotion) {
    let lastScrollY = window.scrollY;

    window.addEventListener(
      "scroll",
      () => {
        const currentScrollY = window.scrollY;
        header.classList.toggle("nav-scrolled", currentScrollY > 4);

        if (currentScrollY > lastScrollY && currentScrollY > 120) {
          header.classList.add("nav-hidden");
        } else {
          header.classList.remove("nav-hidden");
        }

        lastScrollY = currentScrollY;
      },
      { passive: true },
    );
  }
</script>
