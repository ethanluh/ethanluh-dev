---
const links = [
  { label: "research", href: "#research" },
  { label: "projects", href: "#projects" },
  { label: "about", href: "#about" },
  { label: "contact", href: "#contact" },
];
---

<header class="border-b border-bark">
  <nav
    class="max-w-3xl mx-auto flex flex-wrap items-center justify-between gap-2 px-6 py-3 font-mono text-xs uppercase tracking-widest"
  >
    <a href="/" class="text-parchment/80 hover:text-moss transition-colors duration-150">Ethan Luh</a>
    <ul class="flex gap-5">
      {
        links.map((link) => (
          <li>
            <a href={link.href} class="text-stone hover:text-moss transition-colors duration-150">
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</header>
