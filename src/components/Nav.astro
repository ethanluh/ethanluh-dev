---
import { copy } from "../lib/copy";
import ThemeToggle from "./ThemeToggle.astro";
import { CONTACT_EMAIL, SOCIAL_LINKS } from "../content/site";

interface Props {
  email: string;
  socialLinks: { label: string; href: string }[];
}

const { email, socialLinks } = Astro.props;

const links = [
  { label: copy("nav.link.mainPage"), href: "/" },
  { label: copy("nav.link.coursework"), href: "/coursework" },
  { label: copy("nav.link.stack"), href: "/stack" },
  { label: copy("nav.link.about"), href: "/#about" },
  { label: copy("nav.link.howItWorks"), href: "/how-it-works" },
];
const mobileLinks = [...links, { label: copy("nav.link.contact"), href: `mailto:${CONTACT_EMAIL}` }];
---

<header id="site-header" class="border-b border-bark sticky top-0 z-20 bg-canopy/85 backdrop-blur">
  <nav class="max-w-[92rem] mx-auto flex items-center gap-8 px-6 sm:px-10 lg:px-16 py-3 font-mono text-xs uppercase tracking-widest">
    <a href="/" class="flex flex-col leading-tight text-parchment/80 hover:text-moss transition-colors duration-150">
      <span>{copy("nav.brand.name")}</span>
      <span class="text-[0.65rem] tracking-normal normal-case text-stone">{copy("nav.brand.tagline")}</span>
    </a>

    <ul class="nav-links hidden lg:flex flex-nowrap gap-5 items-center ml-auto">
      {
        links.map((link) => (
          <li class="shrink-0">
            <a href={link.href} class="nav-link flex flex-col items-center text-stone hover:text-moss transition-colors duration-150">
              <span class="nav-link-index"></span>
              <span>{link.label}</span>
            </a>
          </li>
        ))
      }
    </ul>

    <button
      type="button"
      data-resume-trigger
      class="hidden lg:flex btn-secondary px-3 py-1.5 min-h-0 text-xs"
    >
      {copy("nav.link.resume")}
    </button>

    <button
      type="button"
      id="nav-menu-toggle"
      aria-expanded="false"
      aria-controls="nav-menu-panel"
      aria-label="Toggle menu"
      class="nav-menu-toggle lg:hidden flex flex-col justify-center gap-1.5 ml-auto cursor-pointer"
    >
      <span class="nav-menu-bar" aria-hidden="true"></span>
      <span class="nav-menu-bar" aria-hidden="true"></span>
      <span class="nav-menu-bar" aria-hidden="true"></span>
    </button>
  </nav>

  <div id="nav-menu-panel" class="nav-menu-panel lg:hidden bg-canopy/85 backdrop-blur border-t border-bark px-6 py-5 font-mono text-xs uppercase tracking-widest" hidden>
    <ul class="nav-links flex flex-col gap-3">
      {
        mobileLinks.map((link) => (
          <li>
            <a href={link.href} class="nav-link tap-target flex items-center gap-2 text-stone hover:text-moss transition-colors duration-150">
              <span class="nav-link-index"></span>
              <span>{link.label}</span>
            </a>
          </li>
        ))
      }
    </ul>
    <div class="nav-menu-divider my-5" aria-hidden="true"></div>
    <ThemeToggle />
    <div class="nav-menu-divider my-5" aria-hidden="true"></div>
    <ul class="flex flex-col gap-3 text-stone">
      <li>
        <a href={`mailto:${CONTACT_EMAIL}`} class="tap-target hover:text-moss transition-colors duration-150">{copy("nav.link.email")}</a>
      </li>
      {SOCIAL_LINKS.map((link) => (
        <li>
          <a href={link.href} target="_blank" rel="noopener noreferrer" class="tap-target hover:text-moss transition-colors duration-150">{link.label}</a>
        </li>
      ))}
      <li>
        <button type="button" data-resume-trigger class="nav-menu-resume tap-target hover:text-moss transition-colors duration-150 cursor-pointer">{copy("nav.link.resume")}</button>
      </li>
    </ul>
  </div>
</header>

<style>
  #site-header {
    transition:
      transform var(--duration-base) var(--ease-field),
      box-shadow var(--duration-base) var(--ease-field);
  }
  #site-header.nav-hidden {
    transform: translateY(-100%);
  }
  #site-header.nav-scrolled {
    box-shadow: 0 4px 12px -6px rgb(0 0 0 / 0.4);
  }

  .nav-links {
    counter-reset: item;
  }
  .nav-links li {
    counter-increment: item;
  }
  .nav-link-index::before {
    content: "0" counter(item) ".";
    color: var(--color-moss);
  }

  .nav-menu-toggle {
    padding: 0.875rem;
    margin-block: -0.875rem;
    margin-inline: -0.875rem;
  }

  /* Fixed overlay so the panel never depends on scrolling the page behind
     it — bottom items were unreachable before when the panel was in-flow
     and taller than the viewport. */
  .nav-menu-panel {
    position: fixed;
    top: var(--header-height);
    left: 0;
    right: 0;
    z-index: 30;
    max-height: calc(100dvh - var(--header-height));
    overflow-y: auto;
  }

  .nav-menu-bar {
    display: block;
    width: 1.25rem;
    height: 1.5px;
    background-color: var(--color-stone);
    transition: background-color var(--duration-base) var(--ease-field);
  }
  .nav-menu-toggle:hover .nav-menu-bar {
    background-color: var(--color-moss);
  }

  .nav-menu-divider {
    height: 1px;
    background: var(--color-bark);
  }

  .nav-menu-resume {
    text-align: left;
    padding-inline: 0;
    background: none;
    border: none;
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: var(--text-mono, 0.75rem);
  }
</style>

<script>
  const header = document.getElementById("site-header");
  const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  // Publishes the header's real rendered height so IndexRail's sticky
  // offset can sit flush under it instead of guessing a pixel value —
  // header height isn't perfectly constant (it grows slightly right at the
  // lg breakpoint edge, where the nav links get tight before wrapping).
  if (header) {
    const syncHeaderHeight = () => {
      document.documentElement.style.setProperty("--header-height", `${header.getBoundingClientRect().height}px`);
    };
    syncHeaderHeight();
    new ResizeObserver(syncHeaderHeight).observe(header);
  }

  if (header && !prefersReducedMotion) {
    let lastScrollY = window.scrollY;

    window.addEventListener(
      "scroll",
      () => {
        const currentScrollY = window.scrollY;
        header.classList.toggle("nav-scrolled", currentScrollY > 4);

        if (currentScrollY > lastScrollY && currentScrollY > 120) {
          header.classList.add("nav-hidden");
        } else {
          header.classList.remove("nav-hidden");
        }

        lastScrollY = currentScrollY;
      },
      { passive: true },
    );
  }

  const menuToggle = document.getElementById("nav-menu-toggle");
  const menuPanel = document.getElementById("nav-menu-panel");

  function closeMenu() {
    if (!menuToggle || !menuPanel) return;
    // Only return focus to the toggle when it was inside the panel (or lost
    // entirely, i.e. on body) — a click on some unrelated focusable control
    // outside the header has already moved focus where the user intended,
    // and shouldn't be yanked back to the hamburger.
    const activeElement = document.activeElement;
    const shouldReturnFocus =
      activeElement === document.body || (activeElement instanceof Node && menuPanel.contains(activeElement));
    menuToggle.setAttribute("aria-expanded", "false");
    menuPanel.hidden = true;
    if (shouldReturnFocus) menuToggle.focus();
  }

  function openMenu() {
    if (!menuToggle || !menuPanel) return;
    menuToggle.setAttribute("aria-expanded", "true");
    menuPanel.hidden = false;
  }

  if (menuToggle && menuPanel) {
    menuToggle.addEventListener("click", () => {
      if (menuPanel.hidden) openMenu();
      else closeMenu();
    });

    menuPanel.addEventListener("click", (event) => {
      const target = event.target as HTMLElement;
      // The theme toggle is a button inside the panel too, but activating it
      // shouldn't close the menu — only exclude it, not other links/buttons.
      if (target?.closest("[data-theme-toggle]")) return;
      if (target?.closest("a, button")) closeMenu();
    });

    document.addEventListener("click", (event) => {
      const target = event.target as HTMLElement;
      if (!menuPanel.hidden && !header?.contains(target)) closeMenu();
    });

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape" && !menuPanel.hidden) closeMenu();
    });
  }
</script>
