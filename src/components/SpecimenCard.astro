---
import HStarMotif from "./HStarMotif.astro";

interface Props {
  number: string;
  title: string;
  tag: string;
  description: string;
  links?: { label: string; href: string }[];
  pills?: boolean;
}

const { number, title, tag, description, links = [], pills = false } = Astro.props;
const tags = pills ? tag.split(" · ") : [];
---

<article class="specimen card-lift bg-bark border-l-[3px] border-moss rounded-r-sm p-7 shadow-lg shadow-canopy/40 flex gap-5 items-baseline">
  <div class="specimen-num font-mono text-lg text-parchment relative shrink-0">
    {number}
    <span class="flower absolute -top-0.5 left-full ml-1.5 text-lavender text-sm opacity-0" aria-hidden="true">
      &#10047;
    </span>
  </div>
  <div class="flex flex-col flex-1">
    <h3 class="font-display text-xl mb-1 flex items-center gap-2">
      {title}
      <HStarMotif vectorId="diamond" mode="smooth" width={32} height={10} class="specimen-hover-motif" />
    </h3>
    {!pills && <p class="font-mono text-xs text-stone mb-2">{tag}</p>}
    <p class="text-parchment/90 mb-2">{description}</p>
    {
      links.length > 0 && (
        <div class="flex gap-4 font-mono text-xs mb-2">
          {links.map((link) => (
            <a href={link.href} class="text-moss hover:text-parchment transition-colors duration-150">
              {link.label}
            </a>
          ))}
        </div>
      )
    }
    {
      pills && (
        <ul class="tech-tags flex flex-wrap gap-x-4 gap-y-1 font-mono text-xs text-stone mt-auto pt-1">
          {tags.map((entry) => <li>{entry}</li>)}
        </ul>
      )
    }
  </div>
</article>

<style>
  .specimen-num:hover .flower {
    opacity: 1;
    transition: opacity var(--ease-field) 250ms;
  }
  .specimen-hover-motif {
    opacity: 0;
    transition: opacity 180ms var(--ease-field);
  }
  .card-lift:hover .specimen-hover-motif,
  .card-lift:focus-within .specimen-hover-motif {
    opacity: 1;
  }
  .card-lift {
    transition:
      transform var(--duration-base) var(--ease-field),
      box-shadow var(--duration-base) var(--ease-field);
  }
  @media (prefers-reduced-motion: no-preference) {
    .card-lift:hover,
    .card-lift:focus-within {
      transform: translateY(-4px);
      box-shadow: 0 12px 24px -12px rgb(0 0 0 / 0.5);
    }
  }
</style>
