---
interface Props {
  number: string;
  title: string;
  tag: string;
  description: string;
  links?: { label: string; href: string }[];
}

const { number, title, tag, description, links = [] } = Astro.props;
---

<article class="specimen bg-bark border-l-2 border-moss rounded-r-sm p-6 flex gap-5 items-start transition-colors duration-150 hover:bg-bark/80">
  <div class="specimen-num font-mono text-lg text-parchment relative shrink-0 translate-y-0.5">
    {number}
    <span class="flower absolute -top-0.5 left-full ml-1.5 text-lavender text-sm opacity-0" aria-hidden="true">
      &#10047;
    </span>
  </div>
  <div>
    <h3 class="font-display text-xl mb-1">{title}</h3>
    <p class="font-mono text-xs text-stone mb-2">{tag}</p>
    <p class="text-parchment/90 mb-2">{description}</p>
    {
      links.length > 0 && (
        <div class="flex gap-4 font-mono text-xs">
          {links.map((link) =>
            link.href === "#" ? (
              <span class="text-stone">{link.label} — soon</span>
            ) : (
              <a href={link.href} class="text-moss hover:text-parchment transition-colors duration-150">
                {link.label}
              </a>
            )
          )}
        </div>
      )
    }
  </div>
</article>

<style>
  .specimen-num:hover .flower {
    opacity: 1;
    transition: opacity var(--ease-field) 250ms;
  }
</style>
