---
import { copy } from "../lib/copy";
import ThemeToggle from "./ThemeToggle.astro";

interface Props {
  sections?: { label: string; href: string }[];
  email: string;
  socialLinks: { label: string; href: string }[];
  personalSite: { label: string; href: string };
}

const { sections = [], email, socialLinks, personalSite } = Astro.props;
---

<aside class="index-rail hidden lg:flex sticky top-[var(--header-height)] self-start flex-col gap-9 shrink-0 w-60 pt-12 pb-12">
  {
    sections.length > 0 && (
      <div>
        <p class="font-mono text-[0.65rem] uppercase tracking-widest text-stone mb-3">{copy("rail.onThisPage")}</p>
        <ul class="flex flex-col gap-2">
          {sections.map((s) => (
            <li>
              <a href={s.href} class="font-mono text-xs uppercase tracking-widest text-parchment/80 hover:text-moss transition-colors duration-150">
                {s.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    )
  }

  <div>
    <p class="font-mono text-[0.65rem] uppercase tracking-widest text-stone mb-3">{copy("rail.contact")}</p>
    <ul class="flex flex-col gap-2 font-mono text-xs uppercase tracking-widest text-stone">
      <li>
        <a href={`mailto:${email}`} class="hover:text-moss transition-colors duration-150">{email}</a>
      </li>
      {socialLinks.map((link) => (
        <li>
          <a href={link.href} target="_blank" rel="noopener noreferrer" class="hover:text-moss transition-colors duration-150">
            {link.label}
          </a>
        </li>
      ))}
      <li>
        <button type="button" data-resume-trigger class="uppercase hover:text-moss transition-colors duration-150 cursor-pointer">Resume</button>
      </li>
      <li class="flex items-center gap-2">
        <span class="rail-dot transition-colors duration-150" aria-hidden="true">&middot;</span>
        <a href={personalSite.href} class="hover:text-moss transition-colors duration-150">{personalSite.label}</a>
      </li>
    </ul>
  </div>

  <ThemeToggle />
</aside>

<style>
  .rail-dot:hover {
    color: var(--color-lavender);
  }
</style>
