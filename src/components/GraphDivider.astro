---
interface Props {
  flip?: boolean;
  class?: string;
}

const { flip = false, class: className = "" } = Astro.props;
---

<div class:list={["graph-divider flex justify-center py-6", className]}>
  <svg
    width="120"
    height="28"
    viewBox="0 0 120 28"
    fill="none"
    aria-hidden="true"
    focusable="false"
    style={flip ? "transform: scaleX(-1)" : undefined}
  >
    <line x1="6" y1="20" x2="50" y2="8" />
    <line x1="50" y1="8" x2="90" y2="20" />
    <line x1="90" y1="20" x2="114" y2="10" />
    <circle cx="6" cy="20" r="3" />
    <circle cx="50" cy="8" r="3" />
    <circle cx="90" cy="20" r="3" />
    <circle cx="114" cy="10" r="3" />
  </svg>
</div>

<style>
  .graph-divider svg line {
    stroke: var(--color-stone);
    stroke-width: 1;
    opacity: 0.3;
  }

  .graph-divider svg circle {
    fill: var(--color-stone);
    opacity: 0.3;
  }
</style>
