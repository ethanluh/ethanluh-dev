---
import { getHStarEntry } from "../data/hstar";
import { catmullRomToBezierPath, normalizedPoints } from "../lib/hstarPath";

interface Props {
  vectorId: string;
  mode?: "bar" | "smooth";
  width?: number;
  height?: number;
  strokeOnly?: boolean;
  opacity?: number;
  flip?: boolean;
  class?: string;
}

const {
  vectorId,
  mode = "smooth",
  width = 240,
  height = 32,
  strokeOnly = false,
  opacity = 1,
  flip = false,
  class: className = "",
} = Astro.props;

const entry = getHStarEntry(vectorId);
const points = normalizedPoints(entry.hstar, width, height);

const barGap = 0.15;
const barWidth = points.length > 0 ? (width / points.length) * (1 - barGap) : 0;

let fillPath = "";
if (mode === "smooth" && !strokeOnly) {
  const curve = catmullRomToBezierPath(points);
  const last = points[points.length - 1];
  const first = points[0];
  fillPath = `${curve} L ${last[0]} ${height} L ${first[0]} ${height} Z`;
}
const strokePath = mode === "smooth" ? catmullRomToBezierPath(points) : "";
---

<svg
  class:list={["hstar-motif", className]}
  width={width}
  height={height}
  viewBox={`0 0 ${width} ${height}`}
  fill="none"
  opacity={opacity}
  aria-hidden="true"
  focusable="false"
  style={flip ? "transform: scaleX(-1)" : undefined}
  data-vector-id={vectorId}
>
  {
    mode === "bar" ? (
      points.map(([x, y]) => (
        <rect
          x={x - barWidth / 2}
          y={y}
          width={barWidth}
          height={height - y}
          class="hstar-bar"
        />
      ))
    ) : (
      <>
        {!strokeOnly && <path d={fillPath} class="hstar-fill" stroke="none" />}
        <path d={strokePath} class="hstar-stroke" fill="none" />
      </>
    )
  }
</svg>

<style>
  .hstar-bar,
  .hstar-fill {
    fill: var(--color-moss);
  }
  .hstar-stroke {
    stroke: var(--color-moss);
    stroke-width: 1.5;
    stroke-linecap: round;
  }
</style>
