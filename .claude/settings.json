{
	"permissions": {
		"allow": [
			"Bash(pytest*)",
			"Bash(ruff*)",
			"Bash(mypy*)",
			"Bash(uv*)",
			"Bash(git status)",
			"Bash(git diff*)",
			"Bash(git log*)",
			"Bash(make*)",
			"Bash(cmake*)"
		],
		"deny": [
			"Bash(rm -rf*)",
			"Bash(git push --force*)",
			"Bash(git reset --hard*)"
		]
	},
	"hooks": {
		"PreToolUse": [
			{
				"matcher": "Bash",
				"hooks": [
					{
						"type": "command",
						"command": "bash .claude/hooks/check-declared-direction.sh"
					}
				]
			}
		]
	}
}
